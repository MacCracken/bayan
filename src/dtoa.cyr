# dtoa.cyr — round-trip-correct f64 <-> decimal conversion for bayan.
# Usage: included by the json profile. Requires: alloc.cyr, string.cyr.
#
# WHY: the old path formatted every f64 as fmt_float_buf(v, buf, 6) — a fixed
# 6-decimal cap that (a) loses ~9 mantissa bits on values like 1/3, (b) flushes
# |x|<5e-7 to 0, and (c) overflowed i64 on |x|>=2^63 / Inf / NaN, emitting the
# NON-JSON token "-.00000-". Parsing used two divergent, both-imprecise atofs
# that disagreed by 1 ULP on identical text, and the exponent apply looped once
# per unit of the exponent VALUE — an algorithmic-complexity DoS.
#
# Replaces all of that:
#   bayan_f64_to_json(bits, buf) — Grisu2 (Loitsch; the miloyip/rapidjson port):
#     integer-only, ALWAYS succeeds (no Dragon4 fallback), output is guaranteed
#     to round-trip and is shortest-or-near-shortest. Non-finite -> "null".
#   bayan_f64_from_json(cstr) — Clinger fast path (exact single-rounding) + a
#     normalized-DiyFp path via the SAME cached-power table, exponent clamped
#     during scanning (no DoS).
# CHANGELOG bayan [1.2.1]; folded into cyrius CHANGELOG [6.4.69].

# ================================================================
# Cached powers of ten as DiyFp significands (u64, bit63 set): sig*2^binexp ==
# 10^decexp correctly rounded to 64 bits, decexp = -348,-340,..,340 (step 8),
# 87 entries. Values 0.5-ULP validated against double-conversion; the binary and
# decimal exponents are closed-form (validated), so only the significands are
# stored. See scratchpad/gen_pow10.py.
# ================================================================
var _D_POW10_SIG: i64[87];
# 10^0 .. 10^22 as EXACT f64 bit patterns (Clinger fast-path: these are the
# powers of ten that are exactly representable as doubles).
var _D_POW10_EXACT: i64[23];
var _D_TABLES_INIT = 0;
var _D_MASK32 = 0xFFFFFFFF;
var _D_BIT63  = 0x8000000000000000;

fn _d_init_tables(): i64 {
    if (_D_TABLES_INIT == 1) { return 0; }
    store64(&_D_POW10_SIG + 0, 0xfa8fd5a0081c0288);
    store64(&_D_POW10_SIG + 8, 0xbaaee17fa23ebf76);
    store64(&_D_POW10_SIG + 16, 0x8b16fb203055ac76);
    store64(&_D_POW10_SIG + 24, 0xcf42894a5dce35ea);
    store64(&_D_POW10_SIG + 32, 0x9a6bb0aa55653b2d);
    store64(&_D_POW10_SIG + 40, 0xe61acf033d1a45df);
    store64(&_D_POW10_SIG + 48, 0xab70fe17c79ac6ca);
    store64(&_D_POW10_SIG + 56, 0xff77b1fcbebcdc4f);
    store64(&_D_POW10_SIG + 64, 0xbe5691ef416bd60c);
    store64(&_D_POW10_SIG + 72, 0x8dd01fad907ffc3c);
    store64(&_D_POW10_SIG + 80, 0xd3515c2831559a83);
    store64(&_D_POW10_SIG + 88, 0x9d71ac8fada6c9b5);
    store64(&_D_POW10_SIG + 96, 0xea9c227723ee8bcb);
    store64(&_D_POW10_SIG + 104, 0xaecc49914078536d);
    store64(&_D_POW10_SIG + 112, 0x823c12795db6ce57);
    store64(&_D_POW10_SIG + 120, 0xc21094364dfb5637);
    store64(&_D_POW10_SIG + 128, 0x9096ea6f3848984f);
    store64(&_D_POW10_SIG + 136, 0xd77485cb25823ac7);
    store64(&_D_POW10_SIG + 144, 0xa086cfcd97bf97f4);
    store64(&_D_POW10_SIG + 152, 0xef340a98172aace5);
    store64(&_D_POW10_SIG + 160, 0xb23867fb2a35b28e);
    store64(&_D_POW10_SIG + 168, 0x84c8d4dfd2c63f3b);
    store64(&_D_POW10_SIG + 176, 0xc5dd44271ad3cdba);
    store64(&_D_POW10_SIG + 184, 0x936b9fcebb25c996);
    store64(&_D_POW10_SIG + 192, 0xdbac6c247d62a584);
    store64(&_D_POW10_SIG + 200, 0xa3ab66580d5fdaf6);
    store64(&_D_POW10_SIG + 208, 0xf3e2f893dec3f126);
    store64(&_D_POW10_SIG + 216, 0xb5b5ada8aaff80b8);
    store64(&_D_POW10_SIG + 224, 0x87625f056c7c4a8b);
    store64(&_D_POW10_SIG + 232, 0xc9bcff6034c13053);
    store64(&_D_POW10_SIG + 240, 0x964e858c91ba2655);
    store64(&_D_POW10_SIG + 248, 0xdff9772470297ebd);
    store64(&_D_POW10_SIG + 256, 0xa6dfbd9fb8e5b88f);
    store64(&_D_POW10_SIG + 264, 0xf8a95fcf88747d94);
    store64(&_D_POW10_SIG + 272, 0xb94470938fa89bcf);
    store64(&_D_POW10_SIG + 280, 0x8a08f0f8bf0f156b);
    store64(&_D_POW10_SIG + 288, 0xcdb02555653131b6);
    store64(&_D_POW10_SIG + 296, 0x993fe2c6d07b7fac);
    store64(&_D_POW10_SIG + 304, 0xe45c10c42a2b3b06);
    store64(&_D_POW10_SIG + 312, 0xaa242499697392d3);
    store64(&_D_POW10_SIG + 320, 0xfd87b5f28300ca0e);
    store64(&_D_POW10_SIG + 328, 0xbce5086492111aeb);
    store64(&_D_POW10_SIG + 336, 0x8cbccc096f5088cc);
    store64(&_D_POW10_SIG + 344, 0xd1b71758e219652c);
    store64(&_D_POW10_SIG + 352, 0x9c40000000000000);
    store64(&_D_POW10_SIG + 360, 0xe8d4a51000000000);
    store64(&_D_POW10_SIG + 368, 0xad78ebc5ac620000);
    store64(&_D_POW10_SIG + 376, 0x813f3978f8940984);
    store64(&_D_POW10_SIG + 384, 0xc097ce7bc90715b3);
    store64(&_D_POW10_SIG + 392, 0x8f7e32ce7bea5c70);
    store64(&_D_POW10_SIG + 400, 0xd5d238a4abe98068);
