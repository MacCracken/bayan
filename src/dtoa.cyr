    store64(&_D_POW10_SIG + 472, 0xf209787bb47d6b85);
    store64(&_D_POW10_SIG + 480, 0xb454e4a179dd1877);
    store64(&_D_POW10_SIG + 488, 0x865b86925b9bc5c2);
    store64(&_D_POW10_SIG + 496, 0xc83553c5c8965d3d);
    store64(&_D_POW10_SIG + 504, 0x952ab45cfa97a0b3);
    store64(&_D_POW10_SIG + 512, 0xde469fbd99a05fe3);
    store64(&_D_POW10_SIG + 520, 0xa59bc234db398c25);
