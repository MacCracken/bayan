# floor(a / b) for b > 0 (cyrius `/` truncates toward zero).
fn _d_floordiv(a, b): i64 {
    var q = a / b;
    if (a < 0) { if (q * b != a) { q = q - 1; } }
    return q;
}
# table accessors — significand from storage; exponents closed-form.
fn _d_sig(idx): i64 { return load64(&_D_POW10_SIG + idx * 8); }
fn _d_decexp(idx): i64 { return (0 - 348) + 8 * idx; }
# binexp = floor(decexp * log2(10)) - 63, with log2(10) ~= 108853/32768 (exact
# for every table entry, validated).
fn _d_binexp(idx): i64 { return _d_floordiv(_d_decexp(idx) * 108853, 32768) - 63; }
# integer 10^n for small nonneg n (0..18).
fn _d_pow10_i(n): i64 {
    var r = 1;
    var i = 0;
    while (i < n) { r = r * 10; i = i + 1; }
    return r;
}

# ---- unsigned 64-bit helpers (i64 holds u64 bit patterns) ----
# a < b as u64: flip both sign bits, then a signed compare yields the u64 order.
fn _d_ult(a, b): i64 { return (a ^ 0x8000000000000000) < (b ^ 0x8000000000000000); }
fn _d_ule(a, b): i64 { if (_d_ult(b, a) == 1) { return 0; } return 1; }

# High 64 bits of (a*b), rounded, both treated as u64 — the DiyFp significand
# multiply (rapidjson DiyFp::Multiply). Splits into 32-bit pieces so each partial
# product fits a register; `>>` is logical so the bit patterns are true unsigned
# products even when the i64 sign bit is set.
fn _d_mul_hi(a, b): i64 {
    var ah = (a >> 32) & _D_MASK32;
    var al = a & _D_MASK32;
    var bh = (b >> 32) & _D_MASK32;
    var bl = b & _D_MASK32;
    var ac = ah * bh;
    var bc = al * bh;
    var ad = ah * bl;
    var bd = al * bl;
    var tmp = ((bd >> 32) & _D_MASK32) + (ad & _D_MASK32) + (bc & _D_MASK32);
    tmp = tmp + 0x80000000;   # round-to-nearest of the discarded low half (1<<31)
    return ac + ((ad >> 32) & _D_MASK32) + ((bc >> 32) & _D_MASK32) + ((tmp >> 32) & _D_MASK32);
}

# Number of decimal digits in a 32-bit value p (1..10).
fn _d_dec_digits32(p): i64 {
    var n = 1;
    while (n < 10) {
        if (_d_ult(p, _d_pow10_i(n)) == 1) { return n; }
        n = n + 1;
    }
    return 10;
}

# Pick the cached-power index so the multiplied result's exponent lands in the
# Grisu window [-59,-32]. Exactly one 8-step entry qualifies for a given e (=Mp.e).
fn _d_pick_power(e): i64 {
    var idx = 0;
    while (idx < 87) {
        var pe = _d_binexp(idx) + e + 64;
        if (pe >= (0 - 59)) {
            if (pe <= (0 - 32)) { return idx; }
        }
        idx = idx + 1;
    }
    return 86;
}

# GrisuRound: nudge the last emitted digit down while staying inside the interval
# and getting closer to w (rapidjson GrisuRound). All compares are u64.
fn _d_grisu_round(buf, len, delta, rest, ten_kappa, wp_w): i64 {
    while (1 == 1) {
        if (_d_ult(rest, wp_w) != 1) { return 0; }
        if (_d_ule(ten_kappa, delta - rest) != 1) { return 0; }
        var cond = 0;
        if (_d_ult(rest + ten_kappa, wp_w) == 1) { cond = 1; }
        elif (_d_ult((rest + ten_kappa) - wp_w, wp_w - rest) == 1) { cond = 1; }
        if (cond == 0) { return 0; }
        store8(buf + len - 1, load8(buf + len - 1) - 1);
        rest = rest + ten_kappa;
    }
    return 0;
}

# Grisu2 digit generation. W = scaled value, Mp = scaled upper boundary (same e =
# mp_e), delta = interval width (u64). Writes ASCII digits into buf; returns count;
# writes the decimal power k to kout[0] (value == digits * 10^k).
fn _d_digit_gen(w_f, mp_f, mp_e, delta, buf, kout): i64 {
    var one_f = 1 << (0 - mp_e);
    var one_e = mp_e;
    var wp_w = mp_f - w_f;
    var p1 = (mp_f >> (0 - one_e)) & _D_MASK32;
    var p2 = mp_f & (one_f - 1);
    var kappa = _d_dec_digits32(p1);
    var len = 0;
    while (kappa > 0) {
        var pw = _d_pow10_i(kappa - 1);
        var d = p1 / pw;
        if (d != 0 || len != 0) { store8(buf + len, 48 + d); len = len + 1; }
        p1 = p1 - d * pw;
        kappa = kappa - 1;
        var tmp = ((p1 & _D_MASK32) << (0 - one_e)) + p2;
        if (_d_ule(tmp, delta) == 1) {
            _d_grisu_round(buf, len, delta, tmp, _d_pow10_i(kappa) << (0 - one_e), wp_w);
            store64(kout, kappa);
            return len;
        }
    }
    while (1 == 1) {
        p2 = p2 * 10;
        delta = delta * 10;
        var d2 = (p2 >> (0 - one_e)) & _D_MASK32;
        if (d2 != 0 || len != 0) { store8(buf + len, 48 + d2); len = len + 1; }
        p2 = p2 & (one_f - 1);
        kappa = kappa - 1;
        if (_d_ult(p2, delta) == 1) {
            var scale = _d_pow10_i(0 - kappa);
            _d_grisu_round(buf, len, delta, p2, one_f, wp_w * scale);
            store64(kout, kappa);
            return len;
        }
    }
    store64(kout, kappa);
    return len;
}

# Grisu2 core: f64 bits (finite, nonzero, positive) -> ASCII digits in buf,
# decimal exponent to kout[0]. Returns digit count. value == digits * 10^K.
fn _d_grisu2(bits, buf, kout): i64 {
    var mant = bits & 0x000FFFFFFFFFFFFF;
    var be   = (bits >> 52) & 0x7FF;
    var f = 0;
    var e = 0;
    if (be != 0) { f = mant + 0x0010000000000000; e = be - 1075; }
    else         { f = mant;                       e = 0 - 1074; }

    # NormalizedBoundaries: plus boundary
    var mp_f = (f << 1) + 1;
    var mp_e = e - 1;
    while ((mp_f & 0x0020000000000000) == 0) { mp_f = mp_f << 1; mp_e = mp_e - 1; }
    mp_f = mp_f << 10;
    mp_e = mp_e - 10;
    # minus boundary
    var mm_f = 0;
    if (f == 0x0010000000000000) { mm_f = (f << 2) - 1; }
    else                          { mm_f = (f << 1) - 1; }
    var mm_e = e - 1;
    if (f == 0x0010000000000000) { mm_e = e - 2; }
    mm_f = mm_f << (mm_e - mp_e);

    # normalize v
    var vf = f;
    var ve = e;
    while ((vf & _D_BIT63) == 0) { vf = vf << 1; ve = ve - 1; }

    var idx = _d_pick_power(mp_e);
    var cf = _d_sig(idx);
    var ce = _d_binexp(idx);
    var cdec = _d_decexp(idx);

    var W_f  = _d_mul_hi(vf, cf);
    var Wp_f = _d_mul_hi(mp_f, cf);
    var Wm_f = _d_mul_hi(mm_f, cf);
    Wp_f = Wp_f - 1;
    Wm_f = Wm_f + 1;
    var delta = Wp_f - Wm_f;
    var Wp_e = mp_e + ce + 64;

    var len = _d_digit_gen(W_f, Wp_f, Wp_e, delta, buf, kout);
    # value == digits * 10^(kappa - decexp)  (rapidjson: K=-decexp, then K+=kappa)
    store64(kout, load64(kout) - cdec);
    return len;
}

# write a signed decimal exponent at buf+pos; return chars written.
fn _d_write_exp(buf, pos, e): i64 {
    var n = 1;
    if (e < 0) { store8(buf + pos, 45); e = 0 - e; }
    else       { store8(buf + pos, 43); }
    pos = pos + 1;
    var tmp[8];
    var ti = 0;
    if (e == 0) { store8(&tmp, 48); ti = 1; }
    while (e > 0) { store8(&tmp + ti, 48 + e % 10); ti = ti + 1; e = e / 10; }
    var w = ti;
    while (ti > 0) { ti = ti - 1; store8(buf + pos, load8(&tmp + ti)); pos = pos + 1; }
    return n + w;
}

# Prettify (rapidjson): value == digits * 10^k, decimal point after (len + k).
# Fixed notation for a moderate window, else exponent form. `buf` holds `len`
# ASCII digits on entry. Returns total length.
fn _d_prettify(buf, len, k): i64 {
    var kk = len + k;
    if (len <= kk && kk <= 21) {
        var i = len;
        while (i < kk) { store8(buf + i, 48); i = i + 1; }
        store8(buf + kk, 46);
        store8(buf + kk + 1, 48);
        return kk + 2;
    } elif (0 < kk && kk <= 21) {
        var i2 = len;
        while (i2 > kk) { store8(buf + i2, load8(buf + i2 - 1)); i2 = i2 - 1; }
        store8(buf + kk, 46);
        return len + 1;
    } elif ((0 - 6) < kk && kk <= 0) {
        var offset = 2 - kk;
        var j = len - 1;
        while (j >= 0) { store8(buf + j + offset, load8(buf + j)); j = j - 1; }
        store8(buf, 48);
        store8(buf + 1, 46);
        var z = 0;
        while (z < (0 - kk)) { store8(buf + 2 + z, 48); z = z + 1; }
        return len + offset;
    } elif (len == 1) {
        store8(buf + 1, 101);
        return 2 + _d_write_exp(buf, 2, kk - 1);
    } else {
        # insert '.' after the first digit: move digits[1..len-1] right by one,
        # THEN write '.' at [1]. (The old `t=len..2` loop left buf[1] unmoved and
        # then clobbered it with '.', dropping digit[1] — only bit exponent form.)
        var t = len - 1;
        while (t >= 1) { store8(buf + t + 1, load8(buf + t)); t = t - 1; }
        store8(buf + 1, 46);
        store8(buf + len + 1, 101);
        return len + 2 + _d_write_exp(buf, len + 2, kk - 1);
    }
}

# Public: format an f64 bit pattern as a JSON number into `buf` (no NUL written).
# Returns the byte length. Non-finite -> "null" (4). Handles sign and zero.
fn bayan_f64_to_json(bits, buf): i64 {
    _d_init_tables();
    var be = (bits >> 52) & 0x7FF;
    var mant = bits & 0x000FFFFFFFFFFFFF;
    if (be == 0x7FF) {
        store8(buf, 110); store8(buf + 1, 117); store8(buf + 2, 108); store8(buf + 3, 108);
        return 4;
    }
    var pos = 0;
    if ((bits & _D_BIT63) != 0) { store8(buf, 45); pos = 1; }
    if (be == 0 && mant == 0) {
        store8(buf + pos, 48); store8(buf + pos + 1, 46); store8(buf + pos + 2, 48);
        return pos + 3;
    }
    var pbits = bits & 0x7FFFFFFFFFFFFFFF;
    var kbuf[8];
    var len = _d_grisu2(pbits, buf + pos, &kbuf);
    var k = load64(&kbuf);
    return pos + _d_prettify(buf + pos, len, k);
}

# ================================================================
# Parsing: decimal string -> f64 bit pattern (correctly rounded for the vast
# majority incl. every value bayan_f64_to_json emits; exponent clamped => no DoS).
# ================================================================

# Round a normalized DiyFp (f: 64-bit, bit63 set; e: binary exp; value=f*2^e,
# sign in `neg`) to the nearest f64 bit pattern (round-half-to-even). Handles
# subnormals and overflow (-> +/-Inf).
fn _d_diyfp_to_f64(f, e, neg): i64 {
    var sign = 0;
    if (neg != 0) { sign = _D_BIT63; }
    # unbiased exponent of the leading (bit-63) 1 is (e + 63); biased for the
    # 53-bit form (hidden bit at 2^52) is that + 1023.
    var biased = e + 63 + 1023;
    if (biased >= 2047) { return sign | 0x7FF0000000000000; }   # overflow -> Inf
    var drop = 11;                                              # 64 -> 53 bits
    if (biased <= 0) {
        # subnormal: shift right an extra (1 - biased) bits, exponent field = 0.
        drop = drop + (1 - biased);
        biased = 0;
        if (drop >= 64) { return sign; }                       # underflow -> +/-0
    }
    var low = f & ((1 << drop) - 1);                           # dropped bits
    var m = f >> drop;                                         # kept significand
    var halfway = 1 << (drop - 1);
    # round half to even
    if (_d_ult(halfway, low) == 1) { m = m + 1; }
    elif (low == halfway) { if ((m & 1) == 1) { m = m + 1; } }
    # rounding carry can bump into the next binade
    if (biased == 0) {
        # subnormal: if m reached 2^52 it becomes the smallest normal (biased 1);
        # the bit layout is continuous, so just OR the sign onto m.
        return sign | m;
    }
    if (m >= 0x0020000000000000) {          # 2^53: mantissa overflowed
        m = m >> 1;
        biased = biased + 1;
        if (biased >= 2047) { return sign | 0x7FF0000000000000; }
    }
    # m is in [2^52, 2^53): drop the hidden bit, splice exponent.
    return sign | (biased << 52) | (m & 0x000FFFFFFFFFFFFF);
}

# Core: significand W (u64, the decimal digits as an integer, <= ~19 digits),
# decimal exponent E (value == W * 10^E), sign. Returns the nearest f64 bits.
fn _d_decimal_to_f64(W, E, neg): i64 {
    var sign = 0;
    if (neg != 0) { sign = _D_BIT63; }
    if (W == 0) { return sign; }
    # gross range gates (double range ~ 10^-324 .. 10^308)
    if (E > 309) { return sign | 0x7FF0000000000000; }
    if (E < (0 - 342)) { return sign; }
    # Clinger fast path: W and 10^|E| both exactly representable as doubles
    # (W < 2^53, |E| <= 22) -> a single f64 mul/div is IEEE-correctly-rounded.
    if (_d_ult(W, 0x0020000000000000) == 1) {
        if (E >= (0 - 22)) {
            if (E <= 22) {
                var fv = f64_from(W);
                if (E >= 0) { fv = f64_mul(fv, load64(&_D_POW10_EXACT + E * 8)); }
                else        { fv = f64_div(fv, load64(&_D_POW10_EXACT + (0 - E) * 8)); }
                return fv | sign;
            }
        }
    }
    # normalize W into a DiyFp {wf, we}: bit 63 set.
    var wf = W;
    var we = 0;
    while ((wf & _D_BIT63) == 0) { wf = wf << 1; we = we - 1; }
    # cached power of ten for decimal exponent E (nearest table entry <= E within
    # 8), then correct the residual (E - decexp) with an exact integer 10^r factor.
    var idx = _d_decexp_index(E);
    var cf = _d_sig(idx);
    var cbe = _d_binexp(idx);
    var cdec = _d_decexp(idx);
    # multiply the two DiyFps
    var rf = _d_mul_hi(wf, cf);
    var re = we + cbe + 64;
    # renormalize (mul_hi may leave bit 63 clear by one)
    if ((rf & _D_BIT63) == 0) { rf = rf << 1; re = re - 1; }
    # apply the residual decimal exponent r = E - cdec (|r| < 8) by an exact
    # power-of-ten DiyFp multiply so the cached-power table stays 8-spaced.
    var r = E - cdec;
    if (r != 0) {
        var rp = _d_pow10_i(r);           # r in (0,8): exact, < 2^27
        if (r > 0) {
            var pf = rp;
            var pe = 0;
            while ((pf & _D_BIT63) == 0) { pf = pf << 1; pe = pe - 1; }
            rf = _d_mul_hi(rf, pf);
            re = re + pe + 64;
            if ((rf & _D_BIT63) == 0) { rf = rf << 1; re = re - 1; }
        }
    }
    return _d_diyfp_to_f64(rf, re, neg);
}

# table index whose decimal exponent is the largest multiple-of-8 entry <= E.
fn _d_decexp_index(E): i64 {
    # decexp(idx) = -348 + 8*idx ; want floor((E+348)/8), clamped to [0,86].
    var idx = _d_floordiv(E + 348, 8);
    if (idx < 0) { idx = 0; }
    if (idx > 86) { idx = 86; }
    return idx;
}

# Parse a decimal number to an f64 bit pattern, reading at most `n` bytes from `s`
# and stopping at the first non-number byte. Handles sign, integer/fraction, e/E
# exponent, Inf/NaN. The exponent accumulator SATURATES (no O(exp) loop -> no DoS).
fn bayan_f64_parse(s, n): i64 {
    _d_init_tables();
    var i = 0;
    var neg = 0;
    while (i < n && (load8(s + i) == 32 || load8(s + i) == 9)) { i = i + 1; }
    if (i < n && load8(s + i) == 45) { neg = 1; i = i + 1; }
    elif (i < n && load8(s + i) == 43) { i = i + 1; }
    # NaN / Inf (JSON emits null for these, but accept literals defensively)
    var c0 = 0;
    if (i < n) { c0 = load8(s + i); }
    if (c0 == 110 || c0 == 78) { return 0x7FF8000000000000; }              # n/N -> NaN (also 'null')
    if (c0 == 105 || c0 == 73) {                                           # i/I -> Inf
        if (neg == 1) { return 0xFFF0000000000000; }
        return 0x7FF0000000000000;
    }
    var W = 0;
    var ndig = 0;          # SIGNIFICANT digits accumulated into W (leading zeros excluded)
    var dexp = 0;          # decimal exponent adjustment from position
    var seen = 0;
    # integer part — skip leading zeros (they aren't significant digits)
    while (i < n && load8(s + i) >= 48 && load8(s + i) <= 57) {
        var d = load8(s + i) - 48;
        if (d != 0 || W != 0) {
            if (ndig < 19) { W = W * 10 + d; ndig = ndig + 1; }
            else { dexp = dexp + 1; }    # 20th+ digit: place value bumps the exponent
        }
        seen = 1;
        i = i + 1;
    }
    # fraction
    if (i < n && load8(s + i) == 46) {
        i = i + 1;
        while (i < n && load8(s + i) >= 48 && load8(s + i) <= 57) {
            var d2 = load8(s + i) - 48;
            if (d2 != 0 || W != 0) {
                # significant fraction digit
                if (ndig < 19) { W = W * 10 + d2; ndig = ndig + 1; dexp = dexp - 1; }
            } else {
                dexp = dexp - 1;         # leading fraction zero: shifts magnitude, not significant
            }
            seen = 1;
            i = i + 1;
        }
    }
    if (seen == 0) { return 0; }
    # exponent
    if (i < n && (load8(s + i) == 101 || load8(s + i) == 69)) {
        i = i + 1;
        var esign = 1;
        if (i < n && load8(s + i) == 45) { esign = 0 - 1; i = i + 1; }
        elif (i < n && load8(s + i) == 43) { i = i + 1; }
        var ev = 0;
        while (i < n && load8(s + i) >= 48 && load8(s + i) <= 57) {
            if (ev < 100000) { ev = ev * 10 + (load8(s + i) - 48); }   # SATURATE -> no DoS
            i = i + 1;
        }
        dexp = dexp + esign * ev;
    }
    return _d_decimal_to_f64(W, dexp, neg);
}

# Parse a NUL-terminated decimal cstring (the scan self-delimits at the NUL / any
# non-number byte). Used by #derive(Serialize) deserialize.
fn bayan_f64_from_json(s): i64 { return bayan_f64_parse(s, 2147483647); }

# --- json.cyr ---

# json.cyr — minimal JSON parser and builder
# Usage: include "lib/json.cyr"
# Requires: string.cyr, alloc.cyr, str.cyr, vec.cyr, fmt.cyr, io.cyr
# Internally includes: fnptr.cyr (for streaming-parser fncallN dispatch)
#
# Parses flat JSON objects into key-value pairs.
# Values are stored as strings (callers convert with str_to_int etc).

# v5.8.30: Result-returning *_r variants for the file-loading
# parsers (`bayan_json_parse_file_r`). Bare `bayan_json_parse(src)` keeps its
# best-effort vec return — no clean -1 surface to migrate.

# v5.8.30 — JsonError variants. `JsonIoErr` covers any underlying
# IoError raised while reading the source file; `JsonParseErr` is
# reserved for a future slot when the parser tracks structural
# errors instead of best-effort recovery; `JsonOther` is the
# catch-all. Keep variant-name prefix `Json` to avoid colliding
# with IoError's `Io*` variants in the global enum-variant
# namespace.
enum JsonError {
    JsonIoErr;
    JsonParseErr;
    JsonOther;
}

# JSON value: { key: Str, value: Str }
var JSON_PAIR_SIZE = 16;

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_pair_new.
# Allocates the 16-byte pair via `a`. Returns 0 on OOM.
fn bayan_json_pair_new_a(a, key, value): i64 {
    var p = alloc_via(a, JSON_PAIR_SIZE);
    if (p == 0) { return 0; }
    store64(p, key);
    store64(p + 8, value);
    return p;
}

# Create a new key-value pair for JSON storage. v5.8.36 wrapper.
fn bayan_json_pair_new(key, value): i64 {
    return bayan_json_pair_new_a(default_alloc(), key, value);
}

# Return the key Str from a JSON pair
fn bayan_json_key(p): i64 { return load64(p); }
# Return the value Str from a JSON pair
fn bayan_json_value(p): i64 { return load64(p + 8); }

# Parse a JSON object string into a vec of key-value pairs.
# Handles: {"key": "value", "key2": "value2", "num": 42}
# Returns vec of json_pair pointers.
fn bayan_json_parse(src): i64 {
    var pairs = vec_new();
    var data = str_data(src);
    var slen = str_len(src);
    var ji = 0;
    # Skip to opening brace
    while (ji < slen) {
        if (load8(data + ji) == 123) { ji = ji + 1; break; }
        ji = ji + 1;
    }
    # Parse key-value pairs
    var key = 0;
    var val = 0;
    while (ji < slen) {
        var c = load8(data + ji);
        # Skip whitespace and commas
        if (c == 32) { ji = ji + 1; }
        elif (c == 10) { ji = ji + 1; }
        elif (c == 13) { ji = ji + 1; }
        elif (c == 9) { ji = ji + 1; }
        elif (c == 44) { ji = ji + 1; }
        elif (c == 125) { break; }
        elif (c == 34) {
            # Parse quoted string
            ji = ji + 1;
            var qs = ji;
            while (ji < slen) {
                if (load8(data + ji) == 34) { break; }
                ji = ji + 1;
            }
            var qstr = str_new(data + qs, ji - qs);
            ji = ji + 1;
            # Is this a key or value?
            if (key == 0) {
                key = qstr;
                # Skip to colon
                while (ji < slen) {
                    if (load8(data + ji) == 58) { ji = ji + 1; break; }
                    ji = ji + 1;
                }
            } else {
                val = qstr;
                vec_push(pairs, bayan_json_pair_new(key, val));
                key = 0;
                val = 0;
            }
        } else {
            # Non-string value (number, true, false, null)
            # Note: historical — chained if/break inside while was broken
            # pre-3.2.6 (upstream report from argonaut, fixed long since);
            # keep the flag + || form below anyway — it's clear enough.
            if (key != 0) {
                var vs = ji;
                var done = 0;
                while (ji < slen && done == 0) {
                    var vc = load8(data + ji);
                    if (vc == 44 || vc == 125 || vc == 32 || vc == 10) {
                        done = 1;
                    } else {
                        ji = ji + 1;
                    }
                }
                val = str_new(data + vs, ji - vs);
                vec_push(pairs, bayan_json_pair_new(key, val));
                key = 0;
                val = 0;
            } else {
                ji = ji + 1;
            }
        }
    }
    return pairs;
}

# Find value by key in parsed JSON. Returns Str or 0 if not found.
fn bayan_json_get(pairs, key): i64 {
    if (pairs == 0) { return 0; }
    if (key == 0) { return 0; }
    var len = vec_len(pairs);
    var gi = 0;
    while (gi < len) {
        var p = vec_get(pairs, gi);
        if (str_eq(bayan_json_key(p), key) == 1) {
            return bayan_json_value(p);
        }
        gi = gi + 1;
    }
    return 0;
}

# Get value as integer (0 if not found or not numeric)
fn bayan_json_get_int(pairs, key): i64 {
    var v = bayan_json_get(pairs, key);
    if (v == 0) { return 0; }
    return str_to_int(v);
}

# Build a JSON object from a vec of key-value pairs
fn bayan_json_build(pairs): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    var len = vec_len(pairs);
    var bi = 0;
    while (bi < len) {
        if (bi > 0) { str_builder_add_cstr(sb, ", "); }
        var p = vec_get(pairs, bi);
        str_builder_add_cstr(sb, "\"");
        str_builder_add(sb, bayan_json_key(p));
        str_builder_add_cstr(sb, "\": \"");
        str_builder_add(sb, bayan_json_value(p));
        str_builder_add_cstr(sb, "\"");
        bi = bi + 1;
    }
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

# Parse a JSON file
fn bayan_json_parse_file(path): i64 {
    var buf = alloc(16384);
    var n = file_read_all(path, buf, 16384);
    if (n <= 0) { return vec_new(); }
    return bayan_json_parse(str_new(buf, n));
}

# v5.8.30 — Result variant of bayan_json_parse_file. Open + read are
# pushed through file_open_r / file_read_r so an underlying
# IoError surfaces as Err(JsonIoErr) instead of being silently
# converted to an empty vec (the back-compat behavior of
# `bayan_json_parse_file`).
fn bayan_json_parse_file_r(path): i64 {
    var fd_r = file_open_r(path, 0, 0);
    if (is_err_result(fd_r) == 1) { return Err(JsonIoErr); }
    var fd = load64(fd_r + 8);
    var buf = alloc(16384);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var rd_r = file_read_r(fd, buf + total, 16384 - total);
        if (is_err_result(rd_r) == 1) { sys_close(fd); return Err(JsonIoErr); }
        var n = load64(rd_r + 8);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 16384) { rgo = 0; }
        }
    }
    sys_close(fd);
    if (total == 0) { return Err(JsonIoErr); }
    return Ok(bayan_json_parse(str_new(buf, total)));
}

# ======================================================================
# JSON ENGINE (v5.7.20) — Tagged-value tree with full nesting + escapes
# ======================================================================
#
# Stdlib baseline. RPC-grade scope (custom serializers, binary
# extensions, etc.) is owned by sandhi (lib/sandhi.cyr).
#
# Backward compat: the flat key-value API at the top of this file
# (bayan_json_parse, bayan_json_get, bayan_json_get_int, bayan_json_pair_new, bayan_json_key,
# bayan_json_value, bayan_json_build, bayan_json_parse_file) is preserved unchanged.
# Existing kybernet / argonaut / libro callers stay green.
#
# The new engine below uses a `json_v_*` prefix and a tagged 24-byte
# heap value:
#
#   +0   tag      u64    JTAG_NULL / BOOL / INT / FLOAT / STR / ARR / OBJ
#   +8   payload  u64    i64 / f64 bits / Str ptr / vec ptr
#   +16  reserved u64    0 (future: source span for raw access)
#
# Vec contents:
#   ARR: vec<json_v*> — element values in declaration order
#   OBJ: vec<json_v_pair*> — { key: Str, value: json_v* } pairs in order
#
# Strings (STR tag and OBJ keys) are decoded — \" \\ \/ \b \f \n \r \t
# \uXXXX (UTF-8 encoded) are all resolved at parse time. The Str ptr
# holds the decoded byte sequence, not the source-text bytes.
#
# Numbers: parsed as INT if the source has no `.` `e` `E`; else FLOAT.
# Float parsing handles scientific notation `3.14e10` / `1.5E-3`.
#
# Errors: parse failures set _json_err_msg (cstr) and _json_err_pos
# (input byte offset). bayan_json_v_parse* returns 0 on error.

var JTAG_NULL  = 0;
var JTAG_BOOL  = 1;
var JTAG_INT   = 2;
var JTAG_FLOAT = 3;
var JTAG_STR   = 4;
var JTAG_ARR   = 5;
var JTAG_OBJ   = 6;

var JV_SIZE = 24;

# Legacy single-threaded last-error slots. As of v1.0.3 the parser keys off a
# per-call state struct (see "Reentrant parser state" below), so these are
# populated by the globals-compat entry points (bayan_json_v_parse_str /
# bayan_json_v_parse / bayan_json_stream_parse) AFTER a parse returns, purely so
# bayan_json_last_error()/_pos() keep working for existing single-threaded
# callers. Concurrent parsers must use bayan_json_v_parse_ctx and read the error
# from their own state via bayan_json_state_error()/_pos().
var _json_err_msg = 0;
var _json_err_pos = 0;

# Return the last parse error message (cstr) — set on bayan_json_v_parse* failure.
fn bayan_json_last_error(): i64 {
    if (_json_err_msg == 0) { return ""; }
    return _json_err_msg;
}

# Return the last parse error byte offset — set on bayan_json_v_parse* failure.
fn bayan_json_last_error_pos(): i64 { return _json_err_pos; }

# === Constructors ===

# v5.8.36 — Allocator-as-first-arg internal jv-cell allocator.
# Returns 0 on OOM (caller must check). Used by every json_v_*_new_a
# constructor below.
fn _jv_alloc_a(a, tag): i64 {
    var v = alloc_via(a, JV_SIZE);
    if (v == 0) { return 0; }
    store64(v, tag);
    store64(v + 8, 0);
    store64(v + 16, 0);
    return v;
}

# Internal jv-cell allocator (back-compat wrapper).
fn _jv_alloc(tag): i64 { return _jv_alloc_a(default_alloc(), tag); }

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_null.
fn bayan_json_v_null_a(a): i64 { return _jv_alloc_a(a, JTAG_NULL); }

# Create a new JTAG_NULL value. v5.8.36 wrapper.
fn bayan_json_v_null(): i64 { return _jv_alloc(JTAG_NULL); }

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_bool_new.
fn bayan_json_v_bool_new_a(a, b): i64 {
    var v = _jv_alloc_a(a, JTAG_BOOL);
    if (v == 0) { return 0; }
    if (b == 0) { store64(v + 8, 0); }
    else        { store64(v + 8, 1); }
    return v;
}

# Create a new JTAG_BOOL value (b is 0 or 1). v5.8.36 wrapper.
fn bayan_json_v_bool_new(b): i64 {
    return bayan_json_v_bool_new_a(default_alloc(), b);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_int_new.
fn bayan_json_v_int_new_a(a, n): i64 {
    var v = _jv_alloc_a(a, JTAG_INT);
    if (v == 0) { return 0; }
    store64(v + 8, n);
    return v;
}

# Create a new JTAG_INT value (n is i64). v5.8.36 wrapper.
fn bayan_json_v_int_new(n): i64 {
    return bayan_json_v_int_new_a(default_alloc(), n);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_float_new.
fn bayan_json_v_float_new_a(a, f): i64 {
    var v = _jv_alloc_a(a, JTAG_FLOAT);
    if (v == 0) { return 0; }
    store64(v + 8, f);
    return v;
}

# Create a new JTAG_FLOAT value (f is f64 bit pattern). v5.8.36 wrapper.
fn bayan_json_v_float_new(f): i64 {
    return bayan_json_v_float_new_a(default_alloc(), f);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_str_new.
fn bayan_json_v_str_new_a(a, s): i64 {
    var v = _jv_alloc_a(a, JTAG_STR);
    if (v == 0) { return 0; }
    store64(v + 8, s);
    return v;
}

# Create a new JTAG_STR value (s is a Str ptr). v5.8.36 wrapper.
fn bayan_json_v_str_new(s): i64 {
    return bayan_json_v_str_new_a(default_alloc(), s);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_arr_new.
# Allocates BOTH the jv-cell AND the inner vec via `a`.
fn bayan_json_v_arr_new_a(a): i64 {
    var v = _jv_alloc_a(a, JTAG_ARR);
    if (v == 0) { return 0; }
    var inner = vec_new_a(a);
    if (inner == 0) { return 0; }
    store64(v + 8, inner);
    return v;
}

# Create an empty JTAG_ARR value. v5.8.36 wrapper. Append via
# bayan_json_v_arr_push (use bayan_json_v_arr_push_a if you need the same
# allocator threaded through grows).
fn bayan_json_v_arr_new(): i64 {
    return bayan_json_v_arr_new_a(default_alloc());
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_obj_new.
# Allocates BOTH the jv-cell AND the inner pairs vec via `a`.
fn bayan_json_v_obj_new_a(a): i64 {
    var v = _jv_alloc_a(a, JTAG_OBJ);
    if (v == 0) { return 0; }
    var inner = vec_new_a(a);
    if (inner == 0) { return 0; }
    store64(v + 8, inner);
    return v;
}

# Create an empty JTAG_OBJ value. v5.8.36 wrapper.
fn bayan_json_v_obj_new(): i64 {
    return bayan_json_v_obj_new_a(default_alloc());
}

# v5.8.36 — Allocator-as-first-arg variant of _jv_pair_new.
fn _jv_pair_new_a(a, key, val): i64 {
    var p = alloc_via(a, 16);
    if (p == 0) { return 0; }
    store64(p, key);
    store64(p + 8, val);
    return p;
}

# A pair is a 16-byte heap struct: { key: Str @ +0, value: json_v* @ +8 }.
# v5.8.36 wrapper.
fn _jv_pair_new(key, val): i64 {
    return _jv_pair_new_a(default_alloc(), key, val);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_arr_push.
# Routes any vec-grow through `a`. Returns -1 on grow OOM
# (vs. back-compat which aborts via vec_push).
fn bayan_json_v_arr_push_a(a, arr, val): i64 {
    if (arr == 0) { return 0 - 1; }
    if (load64(arr) != JTAG_ARR) { return 0 - 1; }
    return vec_push_a(a, load64(arr + 8), val);
}

# Append a value to an array. No-op if arr is not JTAG_ARR.
# v5.8.36 wrapper.
fn bayan_json_v_arr_push(arr, val): i64 {
    if (arr == 0) { return 0; }
    if (load64(arr) != JTAG_ARR) { return 0; }
    vec_push(load64(arr + 8), val);
    return 0;
}

# Append a key/value pair to an object. No-op if obj is not JTAG_OBJ.
fn bayan_json_v_obj_set(obj, key, val): i64 {
    if (obj == 0) { return 0; }
    if (load64(obj) != JTAG_OBJ) { return 0; }
    vec_push(load64(obj + 8), _jv_pair_new(key, val));
    return 0;
}

# === Tag predicates ===

# Return the value tag (JTAG_NULL/BOOL/INT/FLOAT/STR/ARR/OBJ), or -1 if v is 0.
fn bayan_json_v_tag(v): i64 {
    if (v == 0) { return 0 - 1; }
    return load64(v);
}

# Tag predicates — return 1 if v has the given tag, else 0. All return 0 on null v.
fn bayan_json_v_is_null(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_NULL)  { return 1; } return 0; }
# True if v is a JTAG_BOOL value.
fn bayan_json_v_is_bool(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_BOOL)  { return 1; } return 0; }
# True if v is a JTAG_INT value.
fn bayan_json_v_is_int(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_INT)   { return 1; } return 0; }
# True if v is a JTAG_FLOAT value.
fn bayan_json_v_is_float(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_FLOAT) { return 1; } return 0; }
# True if v is a JTAG_STR value.
fn bayan_json_v_is_str(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_STR)   { return 1; } return 0; }
# True if v is a JTAG_ARR value.
fn bayan_json_v_is_arr(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_ARR)   { return 1; } return 0; }
# True if v is a JTAG_OBJ value.
fn bayan_json_v_is_obj(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_OBJ)   { return 1; } return 0; }

# === Value accessors (INT/FLOAT coercion) ===

# Return v as i64 (0 or 1) if v is JTAG_BOOL, else 0.
fn bayan_json_v_bool(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_BOOL) { return 0; }
    return load64(v + 8);
}

# Return v as i64 — coerces JTAG_FLOAT via f64_to. Returns 0 on other tags.
fn bayan_json_v_int(v): i64 {
    if (v == 0) { return 0; }
    var t = load64(v);
    if (t == JTAG_INT) { return load64(v + 8); }
    if (t == JTAG_FLOAT) { return f64_to(load64(v + 8)); }
    return 0;
}

# Return v as f64 bit pattern — coerces JTAG_INT via f64_from. Returns f64_from(0) on other tags.
fn bayan_json_v_float(v): i64 {
    if (v == 0) { return 0; }
    var t = load64(v);
    if (t == JTAG_FLOAT) { return load64(v + 8); }
    if (t == JTAG_INT)   { return f64_from(load64(v + 8)); }
    return f64_from(0);
}

# Return v as Str ptr if v is JTAG_STR, else 0.
fn bayan_json_v_str(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_STR) { return 0; }
    return load64(v + 8);
}

# === Container accessors ===

# Return array length, or 0 if v is not JTAG_ARR.
fn bayan_json_v_arr_len(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_ARR) { return 0; }
    return vec_len(load64(v + 8));
}

# Return array element at index i (json_v* or 0 if out of range / wrong tag).
fn bayan_json_v_arr_get(v, i): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_ARR) { return 0; }
    var arr = load64(v + 8);
    if (i < 0) { return 0; }
    if (i >= vec_len(arr)) { return 0; }
    return vec_get(arr, i);
}

# Return object pair count, or 0 if v is not JTAG_OBJ.
fn bayan_json_v_obj_len(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    return vec_len(load64(v + 8));
}

# Return the n-th object key (Str ptr or 0 if out of range / wrong tag).
fn bayan_json_v_obj_key(v, i): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    if (i < 0) { return 0; }
    if (i >= vec_len(pairs)) { return 0; }
    return load64(vec_get(pairs, i));
}

# Return the n-th object value (json_v* or 0 if out of range / wrong tag).
fn bayan_json_v_obj_val(v, i): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    if (i < 0) { return 0; }
    if (i >= vec_len(pairs)) { return 0; }
    return load64(vec_get(pairs, i) + 8);
}

# bayan_json_v_obj_get — lookup by C-string key. Returns json_v* or 0.
fn bayan_json_v_obj_get(v, key): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    var n = vec_len(pairs);
    var klen = strlen(key);
    var i = 0;
    while (i < n) {
        var p = vec_get(pairs, i);
        var ks = load64(p);
        if (str_len(ks) == klen) {
            if (memeq(str_data(ks), key, klen) == 1) {
                return load64(p + 8);
            }
        }
        i = i + 1;
    }
    return 0;
}

# === Reentrant parser state (v1.0.3) ===
#
# The recursive-descent value parser and the streaming parser both key off a
# per-call state struct threaded as their first argument — NOT module globals —
# so two threads can parse concurrently without clobbering each other's cursor.
# (Pre-1.0.3 this was a process-global _jp_buf/_jp_len/_jp_pos triplet; a second
# parse reset it mid-descent through the first. See
# docs/development/issues/2026-06-23-thoth-json-value-parser-global-cursor-not-thread-safe.md.)
#
# The state is _JP_STATE_SIZE bytes and may be stack- or heap-allocated by the
# caller; the globals-compat wrappers stack-allocate it, so existing callers are
# unaffected and become concurrency-safe. Node allocation still flows through the
# json_v_*_new constructors' default_alloc() — the filed race is the cursor, not
# the node arena (use a thread-safe / thread-local allocator for concurrent node
# allocation).
#
# Layout:
#   +0   buf      cstr   input pointer        (invariant during a parse)
#   +8   len      i64    input length         (invariant during a parse)
#   +16  pos      i64    current byte offset   (advanced through the descent)
#   +24  err_msg  cstr   parse-error message, or 0
#   +32  err_pos  i64    byte offset of the parse error
#   +40  depth    i64    open-container count  (bounds recursion, cap _JP_MAX_DEPTH)
var _JP_STATE_SIZE = 48;

# Recursion-depth cap shared by both descents (value + streaming). 128 matches
# serde_json's default, so Rust→Cyrius ports keep wire parity: a deeper
# document fails the parse with "nesting too deep" through the normal per-call
# error path instead of overflowing the caller's stack (a hostile `[[[[…` body
# costs 2 bytes per level, so any untrusted input can otherwise out-recurse any
# thread stack). See
# docs/development/issues/2026-07-16-agnosai-json-no-recursion-depth-cap.md.
var _JP_MAX_DEPTH = 128;

# Initialise a parser state over (buf, len). pos = 0, error cleared, depth 0.
fn _jp_state_init(ps, buf, len): i64 {
    store64(ps,      buf);
    store64(ps + 8,  len);
    store64(ps + 16, 0);
    store64(ps + 24, 0);
    store64(ps + 32, 0);
    store64(ps + 40, 0);
    return 0;
}

# Record a parse error (message + byte offset) into the per-call state. `pos` is
# passed explicitly because the hot scanners keep the cursor in a local.
fn _jp_set_err(ps, msg, pos): i64 {
    store64(ps + 24, msg);
    store64(ps + 32, pos);
    return 0;
}

# Skip whitespace (space, tab, LF, CR). Advances ps's cursor.
fn _jp_skip_ws(ps): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    var pos = load64(ps + 16);
    while (pos < len) {
        var c = load8(buf + pos);
        if (c == 32 || c == 9 || c == 10 || c == 13) { pos = pos + 1; }
        else { store64(ps + 16, pos); return 0; }
    }
    store64(ps + 16, pos);
    return 0;
}

# Decode a hex digit (returns -1 if not a hex digit).
fn _jp_hex(c): i64 {
    if (c >= 48) { if (c <= 57)  { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    if (c >= 65) { if (c <= 70)  { return c - 55; } }
    return 0 - 1;
}

# Encode codepoint cp as UTF-8 into dst; return bytes written (1..4).
# Caller handles surrogate pairs before calling.
fn _jp_emit_utf8(dst, cp): i64 {
    if (cp < 128)    { store8(dst, cp); return 1; }
    if (cp < 2048)   {
        store8(dst, 192 | (cp >> 6));
        store8(dst + 1, 128 | (cp & 63));
        return 2;
    }
    if (cp < 65536)  {
        store8(dst, 224 | (cp >> 12));
        store8(dst + 1, 128 | ((cp >> 6) & 63));
        store8(dst + 2, 128 | (cp & 63));
        return 3;
    }
    store8(dst, 240 | (cp >> 18));
    store8(dst + 1, 128 | ((cp >> 12) & 63));
    store8(dst + 2, 128 | ((cp >> 6) & 63));
    store8(dst + 3, 128 | (cp & 63));
    return 4;
}

# Parse a JSON string starting at the opening quote. Returns Str* or 0.
# On entry, ps's cursor points at the `"`. On success it points just past the
# closing `"`. The cursor is kept in a local for the hot scan loop and written
# back to ps only on success (error paths abort the whole parse).
fn _jp_parse_string(ps): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    var pos = load64(ps + 16);
    if (pos >= len) { _jp_set_err(ps, "unexpected EOF in string", pos); return 0; }
    if (load8(buf + pos) != 34) { _jp_set_err(ps, "expected string", pos); return 0; }
    pos = pos + 1;
    # Worst case: every escape decoded to fewer bytes. Allocate input-len buf.
    var cap = len - pos + 1;
    var out = alloc(cap + 4);
    var oi = 0;
    while (1 == 1) {
        if (pos >= len) { _jp_set_err(ps, "unterminated string", pos); return 0; }
        var c = load8(buf + pos);
        if (c == 34) { pos = pos + 1; store64(ps + 16, pos); store8(out + oi, 0); return str_new(out, oi); }
        if (c == 92) {
            # Escape sequence
            pos = pos + 1;
            if (pos >= len) { _jp_set_err(ps, "unterminated escape", pos); return 0; }
            var e = load8(buf + pos);
            pos = pos + 1;
            if      (e == 34)  { store8(out + oi,  34); oi = oi + 1; }
            elif    (e == 92)  { store8(out + oi,  92); oi = oi + 1; }
            elif    (e == 47)  { store8(out + oi,  47); oi = oi + 1; }
            elif    (e == 98)  { store8(out + oi,   8); oi = oi + 1; }
            elif    (e == 102) { store8(out + oi,  12); oi = oi + 1; }
            elif    (e == 110) { store8(out + oi,  10); oi = oi + 1; }
            elif    (e == 114) { store8(out + oi,  13); oi = oi + 1; }
            elif    (e == 116) { store8(out + oi,   9); oi = oi + 1; }
            elif    (e == 117) {
                if (pos + 3 >= len) { _jp_set_err(ps, "\\u needs 4 hex digits", pos); return 0; }
                var d0 = _jp_hex(load8(buf + pos));
                var d1 = _jp_hex(load8(buf + pos + 1));
                var d2 = _jp_hex(load8(buf + pos + 2));
                var d3 = _jp_hex(load8(buf + pos + 3));
                if (d0 < 0 || d1 < 0 || d2 < 0 || d3 < 0) { _jp_set_err(ps, "\\u: bad hex digit", pos); return 0; }
                pos = pos + 4;
                var cp = (d0 << 12) | (d1 << 8) | (d2 << 4) | d3;
                # Surrogate pair handling
                if (cp >= 0xD800 && cp <= 0xDBFF) {
                    # High surrogate — expect low surrogate next
                    if (pos + 5 >= len) { _jp_set_err(ps, "incomplete surrogate pair", pos); return 0; }
                    if (load8(buf + pos) != 92 || load8(buf + pos + 1) != 117) {
                        _jp_set_err(ps, "expected low surrogate after high", pos);
                        return 0;
                    }
                    pos = pos + 2;
                    var l0 = _jp_hex(load8(buf + pos));
                    var l1 = _jp_hex(load8(buf + pos + 1));
                    var l2 = _jp_hex(load8(buf + pos + 2));
                    var l3 = _jp_hex(load8(buf + pos + 3));
                    if (l0 < 0 || l1 < 0 || l2 < 0 || l3 < 0) {
                        _jp_set_err(ps, "low surrogate: bad hex", pos); return 0;
                    }
                    pos = pos + 4;
                    var lo = (l0 << 12) | (l1 << 8) | (l2 << 4) | l3;
                    if (lo < 0xDC00 || lo > 0xDFFF) { _jp_set_err(ps, "invalid low surrogate", pos); return 0; }
                    cp = 0x10000 + ((cp - 0xD800) << 10) + (lo - 0xDC00);
                }
                elif (cp >= 0xDC00 && cp <= 0xDFFF) {
                    _jp_set_err(ps, "unexpected low surrogate", pos);
                    return 0;
                }
                oi = oi + _jp_emit_utf8(out + oi, cp);
            }
            else { _jp_set_err(ps, "unknown escape sequence", pos); return 0; }
        }
        else {
            # Ordinary byte
            store8(out + oi, c);
            oi = oi + 1;
            pos = pos + 1;
        }
    }
    return 0;
}

# Parse a number. Returns json_v* (INT or FLOAT) or 0. Cursor kept in a local;
# written back to ps before the (allocating) constructor call on success.
fn _jp_parse_number(ps): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    var pos = load64(ps + 16);
    var start = pos;
    var is_float = 0;
    # Optional minus
    if (pos < len && load8(buf + pos) == 45) { pos = pos + 1; }
    # Integer part
    while (pos < len) {
        var c = load8(buf + pos);
        if (c >= 48 && c <= 57) { pos = pos + 1; }
        else { break; }
    }
    # Fraction
    if (pos < len && load8(buf + pos) == 46) {
        is_float = 1;
        pos = pos + 1;
        while (pos < len) {
            var c2 = load8(buf + pos);
            if (c2 >= 48 && c2 <= 57) { pos = pos + 1; }
            else { break; }
        }
    }
    # Exponent
    if (pos < len) {
        var ec = load8(buf + pos);
        if (ec == 101 || ec == 69) {
            is_float = 1;
            pos = pos + 1;
            if (pos < len) {
                var sg = load8(buf + pos);
                if (sg == 43 || sg == 45) { pos = pos + 1; }
            }
            while (pos < len) {
                var c3 = load8(buf + pos);
                if (c3 >= 48 && c3 <= 57) { pos = pos + 1; }
                else { break; }
            }
        }
    }
    if (pos == start) { _jp_set_err(ps, "expected number", pos); return 0; }
    store64(ps + 16, pos);
    if (is_float == 1) {
        var fbits = _jp_atof(buf + start, pos - start);
        return bayan_json_v_float_new(fbits);
    }
    var iv = _jp_atoi(buf + start, pos - start);
    return bayan_json_v_int_new(iv);
}

# Parse a signed integer from buf[0..len). Returns i64.
fn _jp_atoi(buf, len): i64 {
    var i = 0;
    var sign = 1;
    if (len > 0 && load8(buf) == 45) { sign = 0 - 1; i = 1; }
    var n = 0;
    while (i < len) {
        n = n * 10 + (load8(buf + i) - 48);
        i = i + 1;
    }
    return sign * n;
}

# Parse a float from buf[0..len). Returns f64 bit pattern.
# Handles signed mantissa, optional fraction, optional signed exponent.
# v1.2.1: delegates to the correctly-rounded, DoS-safe parser in dtoa.cyr. The
# old body accumulated digits in f64 (imprecise, disagreed with math f64_parse by
# 1 ULP) and applied the exponent as a loop of once-per-unit-of-exponent-VALUE
# f64 muls (O(exp) -> a 17-byte "1e100000000" burned ~237 ms). See dtoa.cyr.
fn _jp_atof(buf, len): i64 { return bayan_f64_parse(buf, len); }

# === Main parse entry ===

# Recursive value parser. Returns json_v* or 0. The structural parsers cross
# sub-parser call boundaries, so they read/advance the cursor directly in ps
# (ps + 16) rather than caching it — no local/state desync is possible.
fn _jp_parse_value(ps): i64 {
    _jp_skip_ws(ps);
    var buf = load64(ps);
    var len = load64(ps + 8);
    var pos = load64(ps + 16);
    if (pos >= len) { _jp_set_err(ps, "unexpected EOF", pos); return 0; }
    var c = load8(buf + pos);
    if (c == 123 || c == 91) {
        # Containers recurse — bound the descent before entering (scalars can't
        # recurse, so only these two branches touch the depth counter).
        var depth = load64(ps + 40);
        if (depth >= _JP_MAX_DEPTH) { _jp_set_err(ps, "nesting too deep", pos); return 0; }
        store64(ps + 40, depth + 1);
        var v = 0;
        if (c == 123) { v = _jp_parse_object(ps); }
        else          { v = _jp_parse_array(ps); }
        store64(ps + 40, depth);
        return v;
    }
    if (c == 34)  {
        var s = _jp_parse_string(ps);
        if (s == 0) { return 0; }
        return bayan_json_v_str_new(s);
    }
    if (c == 116) {
        if (pos + 3 < len && memeq(buf + pos + 1, "rue", 3) == 1) {
            store64(ps + 16, pos + 4);
            return bayan_json_v_bool_new(1);
        }
        _jp_set_err(ps, "expected 'true'", pos); return 0;
    }
    if (c == 102) {
        if (pos + 4 < len && memeq(buf + pos + 1, "alse", 4) == 1) {
            store64(ps + 16, pos + 5);
            return bayan_json_v_bool_new(0);
        }
        _jp_set_err(ps, "expected 'false'", pos); return 0;
    }
    if (c == 110) {
        if (pos + 3 < len && memeq(buf + pos + 1, "ull", 3) == 1) {
            store64(ps + 16, pos + 4);
            return bayan_json_v_null();
        }
        _jp_set_err(ps, "expected 'null'", pos); return 0;
    }
    if (c == 45 || (c >= 48 && c <= 57)) {
        return _jp_parse_number(ps);
    }
    _jp_set_err(ps, "unexpected character", pos);
    return 0;
}

fn _jp_parse_array(ps): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    if (load8(buf + load64(ps + 16)) != 91) { _jp_set_err(ps, "expected '['", load64(ps + 16)); return 0; }
    store64(ps + 16, load64(ps + 16) + 1);
    var arr = bayan_json_v_arr_new();
    _jp_skip_ws(ps);
    if (load64(ps + 16) < len && load8(buf + load64(ps + 16)) == 93) {
        store64(ps + 16, load64(ps + 16) + 1);
        return arr;
    }
    while (1 == 1) {
        var v = _jp_parse_value(ps);
        if (v == 0) { return 0; }
        bayan_json_v_arr_push(arr, v);
        _jp_skip_ws(ps);
        if (load64(ps + 16) >= len) { _jp_set_err(ps, "unterminated array", load64(ps + 16)); return 0; }
        var c = load8(buf + load64(ps + 16));
        if (c == 44) { store64(ps + 16, load64(ps + 16) + 1); _jp_skip_ws(ps); }
        elif (c == 93) { store64(ps + 16, load64(ps + 16) + 1); return arr; }
        else { _jp_set_err(ps, "expected ',' or ']'", load64(ps + 16)); return 0; }
    }
    return 0;
}

fn _jp_parse_object(ps): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    if (load8(buf + load64(ps + 16)) != 123) { _jp_set_err(ps, "expected '{'", load64(ps + 16)); return 0; }
    store64(ps + 16, load64(ps + 16) + 1);
    var obj = bayan_json_v_obj_new();
    _jp_skip_ws(ps);
    if (load64(ps + 16) < len && load8(buf + load64(ps + 16)) == 125) {
        store64(ps + 16, load64(ps + 16) + 1);
        return obj;
    }
    while (1 == 1) {
        _jp_skip_ws(ps);
        var k = _jp_parse_string(ps);
        if (k == 0) { return 0; }
        _jp_skip_ws(ps);
        if (load64(ps + 16) >= len) { _jp_set_err(ps, "unterminated object", load64(ps + 16)); return 0; }
        if (load8(buf + load64(ps + 16)) != 58) {
            _jp_set_err(ps, "expected ':' after key", load64(ps + 16)); return 0;
        }
        store64(ps + 16, load64(ps + 16) + 1);
        _jp_skip_ws(ps);
        var val = _jp_parse_value(ps);
        if (val == 0) { return 0; }
        bayan_json_v_obj_set(obj, k, val);
        _jp_skip_ws(ps);
        if (load64(ps + 16) >= len) { _jp_set_err(ps, "unterminated object", load64(ps + 16)); return 0; }
        var c = load8(buf + load64(ps + 16));
        if (c == 44) { store64(ps + 16, load64(ps + 16) + 1); }
        elif (c == 125) { store64(ps + 16, load64(ps + 16) + 1); return obj; }
        else { _jp_set_err(ps, "expected ',' or '}'", load64(ps + 16)); return 0; }
    }
    return 0;
}

# === Reentrant parse entry (v1.0.3, thread-safe) ===
#
# bayan_json_v_parse_ctx threads all parser state through `ps` (a caller-owned
# _JP_STATE_SIZE-byte buffer — stack `var ps[48]` or heap `alloc(...)`). It
# touches NO module globals, so concurrent threads each parsing into their own
# `ps` cannot corrupt one another's cursor. On failure it returns 0 and records
# the error in `ps`; read it with bayan_json_state_error()/_pos().

# Size (bytes) a caller must reserve for a parser state passed to *_parse_ctx*.
fn bayan_json_parse_state_size(): i64 { return _JP_STATE_SIZE; }

# Error message (cstr) recorded in a parser state, or "" if none.
fn bayan_json_state_error(ps): i64 {
    var m = load64(ps + 24);
    if (m == 0) { return ""; }
    return m;
}

# Byte offset of the error recorded in a parser state.
fn bayan_json_state_error_pos(ps): i64 { return load64(ps + 32); }

# Reentrant parse — explicit cstr+len into a caller-owned state. Returns
# json_v* or 0; on 0 the error lives in `ps`. Does not touch the legacy globals.
fn bayan_json_v_parse_ctx(ps, buf, len): i64 {
    _jp_state_init(ps, buf, len);
    var v = _jp_parse_value(ps);
    if (v == 0) { return 0; }
    _jp_skip_ws(ps);
    if (load64(ps + 16) != len) {
        _jp_set_err(ps, "trailing content after JSON value", load64(ps + 16));
        return 0;
    }
    return v;
}

# Reentrant parse — Str convenience over bayan_json_v_parse_ctx.
fn bayan_json_v_parse_ctx_str(ps, src): i64 {
    if (src == 0) {
        _jp_state_init(ps, 0, 0);
        _jp_set_err(ps, "null source", 0);
        return 0;
    }
    return bayan_json_v_parse_ctx(ps, str_data(src), str_len(src));
}

# Public parse entry — Str. Returns json_v* or 0.
fn bayan_json_v_parse(src): i64 {
    if (src == 0) { _json_err_msg = "null source"; _json_err_pos = 0; return 0; }
    return bayan_json_v_parse_str(str_data(src), str_len(src));
}

# Public parse entry — explicit cstr+len. Globals-compat wrapper over the
# reentrant path: each call owns a stack-local parser state (so the parse itself
# is now thread-safe), then mirrors the per-call error into the legacy
# bayan_json_last_error()/_pos() slots for source compatibility. Concurrent
# callers that need race-free error reporting should call bayan_json_v_parse_ctx
# directly and read bayan_json_state_error()/_pos().
fn bayan_json_v_parse_str(buf, len): i64 {
    var ps[48];
    var v = bayan_json_v_parse_ctx(&ps, buf, len);
    _json_err_msg = load64(&ps + 24);
    _json_err_pos = load64(&ps + 32);
    return v;
}

# === Serializer ===

# Append a JSON-escaped string into sb, including the surrounding quotes.
fn _jb_append_string(sb, s): i64 {
    str_builder_add_cstr(sb, "\"");
    var data = str_data(s);
    var slen = str_len(s);
    var i = 0;
    while (i < slen) {
        var c = load8(data + i);
        if      (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif    (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif    (c ==  8) { str_builder_add_cstr(sb, "\\b"); }
        elif    (c == 12) { str_builder_add_cstr(sb, "\\f"); }
        elif    (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif    (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif    (c ==  9) { str_builder_add_cstr(sb, "\\t"); }
        elif    (c < 32) {
            # Control char — emit \u00XX
            str_builder_add_cstr(sb, "\\u00");
            var hi = c >> 4;
            var lo = c & 15;
            var hb[3];
            if (hi < 10) { store8(&hb, 48 + hi); } else { store8(&hb, 87 + hi); }
            if (lo < 10) { store8(&hb + 1, 48 + lo); } else { store8(&hb + 1, 87 + lo); }
            store8(&hb + 2, 0);
            str_builder_add_cstr(sb, &hb);
        }
        else {
            var bb[2];
            store8(&bb, c);
            store8(&bb + 1, 0);
            str_builder_add_cstr(sb, &bb);
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "\"");
    return 0;
}

# Emit '\n' followed by (indent * level) spaces. Pretty-mode helper.
fn _jb_emit_indent(sb, indent, level): i64 {
    str_builder_add_byte(sb, 10);
    var total = indent * level;
    var i = 0;
    while (i < total) {
        str_builder_add_byte(sb, 32);
        i = i + 1;
    }
    return 0;
}

# Unified compact + pretty walker. `indent` param drives mode:
# 0 = compact (":" separator), >0 = pretty (newlines, ": ").
# `if n > 0` guards empty-container case for both modes.
# See CHANGELOG [5.7.47].
fn _jb_walk(sb, v, indent, level): i64 {
    if (v == 0) { str_builder_add_cstr(sb, "null"); return 0; }
    var t = load64(v);
    if      (t == JTAG_NULL)  { str_builder_add_cstr(sb, "null"); }
    elif    (t == JTAG_BOOL)  {
        if (load64(v + 8) == 0) { str_builder_add_cstr(sb, "false"); }
        else                    { str_builder_add_cstr(sb, "true");  }
    }
    elif    (t == JTAG_INT)   {
        var nb[24];
        var nl = fmt_int_buf(load64(v + 8), &nb);
        store8(&nb + nl, 0);
        str_builder_add_cstr(sb, &nb);
    }
    elif    (t == JTAG_FLOAT) {
        var fb[64];
        # v1.2.1: Grisu2 round-trip-correct (was fmt_float_buf(,6) — 6-decimal cap
        # lost mantissa bits, flushed |x|<5e-7 to 0, and emitted "-.00000-" for
        # Inf/NaN/>=2^63). Non-finite -> "null". See dtoa.cyr.
        var fl = bayan_f64_to_json(load64(v + 8), &fb);
        store8(&fb + fl, 0);
        str_builder_add_cstr(sb, &fb);
    }
    elif    (t == JTAG_STR)   { _jb_append_string(sb, load64(v + 8)); }
    elif    (t == JTAG_ARR)   {
        str_builder_add_cstr(sb, "[");
        var arr = load64(v + 8);
        var n = vec_len(arr);
        if (n > 0) {
            var i = 0;
            while (i < n) {
                if (i > 0) { str_builder_add_cstr(sb, ","); }
                if (indent > 0) { _jb_emit_indent(sb, indent, level + 1); }
                _jb_walk(sb, vec_get(arr, i), indent, level + 1);
                i = i + 1;
            }
            if (indent > 0) { _jb_emit_indent(sb, indent, level); }
        }
        str_builder_add_cstr(sb, "]");
    }
    elif    (t == JTAG_OBJ)   {
        str_builder_add_cstr(sb, "{");
        var pairs = load64(v + 8);
        var pn = vec_len(pairs);
        if (pn > 0) {
            var pi = 0;
            while (pi < pn) {
                if (pi > 0) { str_builder_add_cstr(sb, ","); }
                if (indent > 0) { _jb_emit_indent(sb, indent, level + 1); }
                var p = vec_get(pairs, pi);
                _jb_append_string(sb, load64(p));
                if (indent > 0) { str_builder_add_cstr(sb, ": "); }
                else            { str_builder_add_cstr(sb, ":");  }
                _jb_walk(sb, load64(p + 8), indent, level + 1);
                pi = pi + 1;
            }
            if (indent > 0) { _jb_emit_indent(sb, indent, level); }
        }
        str_builder_add_cstr(sb, "}");
    }
    else {
        str_builder_add_cstr(sb, "null");
    }
    return 0;
}

# bayan_json_v_build — serialize a tagged value tree to a Str (compact).
fn bayan_json_v_build(v): i64 {
    var sb = str_builder_new();
    _jb_walk(sb, v, 0, 0);
    return str_builder_build(sb);
}

# bayan_json_v_build_pretty — serialize a tagged value tree with newlines + indent.
# `indent` is the spaces per level; `indent <= 0` falls back to compact.
fn bayan_json_v_build_pretty(v, indent): i64 {
    if (indent <= 0) { return bayan_json_v_build(v); }
    var sb = str_builder_new();
    _jb_walk(sb, v, indent, 0);
    return str_builder_build(sb);
}

# ======================================================================
# STREAMING PARSER (v5.7.41) — event-driven, no tree allocation
# ======================================================================
#
# For multi-MB JSON inputs that don't fit the tagged-tree memory model.
# Caller allocates a handler struct, fills in the callbacks they care
# about (others stay 0 = no-op), and the driver fires events as it walks.
#
# Handler layout (96 bytes):
#   +0   ctx              user pointer (1st arg to every callback)
#   +8   on_object_start  fnptr or 0  fncall1(ctx)
#   +16  on_object_end    fnptr or 0  fncall1(ctx)
#   +24  on_array_start   fnptr or 0  fncall1(ctx)
#   +32  on_array_end     fnptr or 0  fncall1(ctx)
#   +40  on_key           fnptr or 0  fncall2(ctx, key_str)
#   +48  on_string        fnptr or 0  fncall2(ctx, value_str)
#   +56  on_int           fnptr or 0  fncall2(ctx, value_i64)
#   +64  on_float         fnptr or 0  fncall2(ctx, value_f64_bits)
#   +72  on_bool          fnptr or 0  fncall2(ctx, value_0_or_1)
#   +80  on_null          fnptr or 0  fncall1(ctx)
#   +88  on_error         fnptr or 0  fncall3(ctx, msg_cstr, pos)
#
# Lex state is the same per-call parser state struct the tree parser uses (`ps`,
# threaded as the first argument), so the shared helpers _jp_skip_ws,
# _jp_parse_string, _jp_atoi, _jp_atof, _jp_set_err are reused as-is and the
# streaming parser is reentrant too. This keeps the streaming surface ~210 LOC
# instead of ~400.

var JS_EV_OBJECT_START = 0;
var JS_EV_OBJECT_END   = 1;
var JS_EV_ARRAY_START  = 2;
var JS_EV_ARRAY_END    = 3;
var JS_EV_KEY          = 4;
var JS_EV_STRING       = 5;
var JS_EV_INT          = 6;
var JS_EV_FLOAT        = 7;
var JS_EV_BOOL         = 8;
var JS_EV_NULL         = 9;
var JS_EV_ERROR        = 10;
var JS_EV_COUNT        = 11;

var _JS_HANDLER_SIZE = 96;

# Allocate a handler with all callback slots 0 (no-op). `ctx` is the
# user pointer threaded through every callback as its first argument.
fn bayan_json_stream_handler_new(ctx): i64 {
    var h = alloc(_JS_HANDLER_SIZE);
    var i = 0;
    while (i < _JS_HANDLER_SIZE) { store64(h + i, 0); i = i + 8; }
    store64(h, ctx);
    return h;
}

# Bind callback `fp` to event `event_id`. Returns 0 on success, -1 on
# bad event_id. Pass fp=0 to clear an event.
fn bayan_json_stream_on(h, event_id, fp): i64 {
    if (event_id < 0 || event_id >= JS_EV_COUNT) { return 0 - 1; }
    store64(h + 8 + event_id * 8, fp);
    return 0;
}

fn _js_ctx(h): i64 { return load64(h); }
fn _js_cb(h, event_id): i64 { return load64(h + 8 + event_id * 8); }

# Record the error into the per-call state + fire on_error if registered.
fn _js_emit_error(ps, h, msg): i64 {
    var pos = load64(ps + 16);
    _jp_set_err(ps, msg, pos);
    var fp = _js_cb(h, JS_EV_ERROR);
    if (fp != 0) { fncall3(fp, _js_ctx(h), msg, pos); }
    return 0;
}

# Relay a _jp_set_err-set error through to on_error (for paths that
# call _jp_parse_string and get a 0 back — ps's error slots are already
# populated, just need to forward).
fn _js_relay_err(ps, h): i64 {
    var fp = _js_cb(h, JS_EV_ERROR);
    if (fp != 0) { fncall3(fp, _js_ctx(h), load64(ps + 24), load64(ps + 32)); }
    return 0;
}

# Number parser — mirrors _jp_parse_number's lex but emits via
# callback instead of allocating json_v*. Returns 0 on success, -1 on
# error.
fn _js_parse_number(ps, h): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    var pos = load64(ps + 16);
    var start = pos;
    var is_float = 0;
    if (pos < len && load8(buf + pos) == 45) { pos = pos + 1; }
    while (pos < len) {
        var c = load8(buf + pos);
        if (c >= 48 && c <= 57) { pos = pos + 1; }
        else { break; }
    }
    if (pos < len && load8(buf + pos) == 46) {
        is_float = 1;
        pos = pos + 1;
        while (pos < len) {
            var c2 = load8(buf + pos);
            if (c2 >= 48 && c2 <= 57) { pos = pos + 1; }
            else { break; }
        }
    }
    if (pos < len) {
        var ec = load8(buf + pos);
        if (ec == 101 || ec == 69) {
            is_float = 1;
            pos = pos + 1;
            if (pos < len) {
                var sg = load8(buf + pos);
                if (sg == 43 || sg == 45) { pos = pos + 1; }
            }
            while (pos < len) {
                var c3 = load8(buf + pos);
                if (c3 >= 48 && c3 <= 57) { pos = pos + 1; }
                else { break; }
            }
        }
    }
    if (pos == start) { store64(ps + 16, pos); _js_emit_error(ps, h, "expected number"); return 0 - 1; }
    store64(ps + 16, pos);
    if (is_float == 1) {
        var fbits = _jp_atof(buf + start, pos - start);
        var fp_f = _js_cb(h, JS_EV_FLOAT);
        if (fp_f != 0) { fncall2(fp_f, _js_ctx(h), fbits); }
    } else {
        var iv = _jp_atoi(buf + start, pos - start);
        var fp_i = _js_cb(h, JS_EV_INT);
        if (fp_i != 0) { fncall2(fp_i, _js_ctx(h), iv); }
    }
    return 0;
}

fn _js_parse_array(ps, h): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    if (load8(buf + load64(ps + 16)) != 91) { _js_emit_error(ps, h, "expected '['"); return 0 - 1; }
    store64(ps + 16, load64(ps + 16) + 1);
    var fp_s = _js_cb(h, JS_EV_ARRAY_START);
    if (fp_s != 0) { fncall1(fp_s, _js_ctx(h)); }
    _jp_skip_ws(ps);
    if (load64(ps + 16) < len && load8(buf + load64(ps + 16)) == 93) {
        store64(ps + 16, load64(ps + 16) + 1);
        var fp_e = _js_cb(h, JS_EV_ARRAY_END);
        if (fp_e != 0) { fncall1(fp_e, _js_ctx(h)); }
        return 0;
    }
    while (1 == 1) {
        if (_js_parse_value(ps, h) != 0) { return 0 - 1; }
        _jp_skip_ws(ps);
        if (load64(ps + 16) >= len) { _js_emit_error(ps, h, "unterminated array"); return 0 - 1; }
        var c = load8(buf + load64(ps + 16));
        if (c == 44) { store64(ps + 16, load64(ps + 16) + 1); _jp_skip_ws(ps); }
        elif (c == 93) {
            store64(ps + 16, load64(ps + 16) + 1);
            var fp_e2 = _js_cb(h, JS_EV_ARRAY_END);
            if (fp_e2 != 0) { fncall1(fp_e2, _js_ctx(h)); }
            return 0;
        } else { _js_emit_error(ps, h, "expected ',' or ']'"); return 0 - 1; }
    }
    return 0;
}

fn _js_parse_object(ps, h): i64 {
    var buf = load64(ps);
    var len = load64(ps + 8);
    if (load8(buf + load64(ps + 16)) != 123) { _js_emit_error(ps, h, "expected '{'"); return 0 - 1; }
    store64(ps + 16, load64(ps + 16) + 1);
    var fp_s = _js_cb(h, JS_EV_OBJECT_START);
    if (fp_s != 0) { fncall1(fp_s, _js_ctx(h)); }
    _jp_skip_ws(ps);
    if (load64(ps + 16) < len && load8(buf + load64(ps + 16)) == 125) {
        store64(ps + 16, load64(ps + 16) + 1);
        var fp_e = _js_cb(h, JS_EV_OBJECT_END);
        if (fp_e != 0) { fncall1(fp_e, _js_ctx(h)); }
        return 0;
    }
    while (1 == 1) {
        _jp_skip_ws(ps);
        var k = _jp_parse_string(ps);
        if (k == 0) { _js_relay_err(ps, h); return 0 - 1; }
        var fp_k = _js_cb(h, JS_EV_KEY);
        if (fp_k != 0) { fncall2(fp_k, _js_ctx(h), k); }
        _jp_skip_ws(ps);
        if (load64(ps + 16) >= len) { _js_emit_error(ps, h, "unterminated object"); return 0 - 1; }
        if (load8(buf + load64(ps + 16)) != 58) { _js_emit_error(ps, h, "expected ':' after key"); return 0 - 1; }
        store64(ps + 16, load64(ps + 16) + 1);
        if (_js_parse_value(ps, h) != 0) { return 0 - 1; }
        _jp_skip_ws(ps);
        if (load64(ps + 16) >= len) { _js_emit_error(ps, h, "unterminated object"); return 0 - 1; }
        var c = load8(buf + load64(ps + 16));
        if (c == 44) { store64(ps + 16, load64(ps + 16) + 1); }
        elif (c == 125) {
            store64(ps + 16, load64(ps + 16) + 1);
            var fp_e2 = _js_cb(h, JS_EV_OBJECT_END);
            if (fp_e2 != 0) { fncall1(fp_e2, _js_ctx(h)); }
            return 0;
        } else { _js_emit_error(ps, h, "expected ',' or '}'"); return 0 - 1; }
    }
    return 0;
}

fn _js_parse_value(ps, h): i64 {
    _jp_skip_ws(ps);
    var buf = load64(ps);
    var len = load64(ps + 8);
    var pos = load64(ps + 16);
    if (pos >= len) { _js_emit_error(ps, h, "unexpected EOF"); return 0 - 1; }
    var c = load8(buf + pos);
    if (c == 123 || c == 91) {
        # Same depth bound as _jp_parse_value — the streaming descent recurses
        # through _js_parse_array/_js_parse_object identically.
        var depth = load64(ps + 40);
        if (depth >= _JP_MAX_DEPTH) { _js_emit_error(ps, h, "nesting too deep"); return 0 - 1; }
        store64(ps + 40, depth + 1);
        var rc = 0;
        if (c == 123) { rc = _js_parse_object(ps, h); }
        else          { rc = _js_parse_array(ps, h); }
        store64(ps + 40, depth);
        return rc;
    }
    if (c == 34)  {
        var s = _jp_parse_string(ps);
        if (s == 0) { _js_relay_err(ps, h); return 0 - 1; }
        var fp_s = _js_cb(h, JS_EV_STRING);
        if (fp_s != 0) { fncall2(fp_s, _js_ctx(h), s); }
        return 0;
    }
    if (c == 116) {
        if (pos + 3 < len && memeq(buf + pos + 1, "rue", 3) == 1) {
            store64(ps + 16, pos + 4);
            var fp_b = _js_cb(h, JS_EV_BOOL);
            if (fp_b != 0) { fncall2(fp_b, _js_ctx(h), 1); }
            return 0;
        }
        _js_emit_error(ps, h, "expected 'true'");
        return 0 - 1;
    }
    if (c == 102) {
        if (pos + 4 < len && memeq(buf + pos + 1, "alse", 4) == 1) {
            store64(ps + 16, pos + 5);
            var fp_b = _js_cb(h, JS_EV_BOOL);
            if (fp_b != 0) { fncall2(fp_b, _js_ctx(h), 0); }
            return 0;
        }
        _js_emit_error(ps, h, "expected 'false'");
        return 0 - 1;
    }
    if (c == 110) {
        if (pos + 3 < len && memeq(buf + pos + 1, "ull", 3) == 1) {
            store64(ps + 16, pos + 4);
            var fp_n = _js_cb(h, JS_EV_NULL);
            if (fp_n != 0) { fncall1(fp_n, _js_ctx(h)); }
            return 0;
        }
        _js_emit_error(ps, h, "expected 'null'");
        return 0 - 1;
    }
    if (c == 45 || (c >= 48 && c <= 57)) {
        return _js_parse_number(ps, h);
    }
    _js_emit_error(ps, h, "unexpected character");
    return 0 - 1;
}

# Public stream-parse entry — explicit cstr+len+handler. Returns 0 on
# success, -1 on error. After error, callers can read bayan_json_last_error()
# and bayan_json_last_error_pos(); the JS_EV_ERROR callback (if registered)
# already fired.
fn bayan_json_stream_parse(buf, len, h): i64 {
    var ps[48];
    _jp_state_init(&ps, buf, len);
    var rc = 0;
    if (_js_parse_value(&ps, h) != 0) {
        rc = 0 - 1;
    } else {
        _jp_skip_ws(&ps);
        if (load64(&ps + 16) != len) {
            _js_emit_error(&ps, h, "trailing content after JSON value");
            rc = 0 - 1;
        }
    }
    # Mirror the per-call error into the legacy last-error slots for back-compat
    # (0/0 on success). Concurrent stream parsers should read the JS_EV_ERROR
    # callback rather than bayan_json_last_error().
    _json_err_msg = load64(&ps + 24);
    _json_err_pos = load64(&ps + 32);
    return rc;
}

# Convenience: stream-parse from a Str.
fn bayan_json_stream_parse_str(src, h): i64 {
    if (src == 0) { _json_err_msg = "null source"; _json_err_pos = 0; return 0 - 1; }
    return bayan_json_stream_parse(str_data(src), str_len(src), h);
}

# ======================================================================
# JSON POINTER (v5.7.42, RFC 6901)
# ======================================================================
#
# Walk the tagged tree by slash-separated path. Returns the referenced
# json_v* or 0 (not found / invalid pointer / can't descend into scalar).
#
# Empty pointer ""           → whole document
# "/foo"                     → root["foo"]
# "/foo/0/bar"               → root["foo"][0]["bar"]
# "/" (just slash)           → root[""] (empty-string key)
# "/a/"                      → a[""] (trailing-slash empty token)
#
# Tokens are unescaped per RFC 6901 §3: "~1" → "/", "~0" → "~". The
# left-to-right single-pass unescape below is equivalent to the spec's
# two-pass "~1 then ~0" order — only "~0" and "~1" are valid escapes,
# so any other "~X" is an error and returns 0.
#
# Array tokens must match `0|[1-9][0-9]*` per RFC 6901 §4. The "-"
# (next-element) token is append-only and has no read meaning, so
# it returns 0.

# Look up (buf, len) as a key in OBJ value `v`. Length-explicit so
# tokens with interior NUL bytes (theoretical via `\u0000`) still match.
fn _jp_obj_lookup(v, buf, len): i64 {
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    var n = vec_len(pairs);
    var i = 0;
    while (i < n) {
        var p = vec_get(pairs, i);
        var ks = load64(p);
        if (str_len(ks) == len) {
            if (memeq(str_data(ks), buf, len) == 1) {
                return load64(p + 8);
            }
        }
        i = i + 1;
    }
    return 0;
}

# Parse (buf, len) as a strict array index per RFC 6901 §4. Returns
# index >= 0, or -1 on invalid (leading zero, non-digit, empty,
# the "-" next-element token, etc.).
fn _jp_parse_idx(buf, len): i64 {
    if (len == 0) { return 0 - 1; }
    var c0 = load8(buf);
    if (c0 == 48) { if (len == 1) { return 0; } return 0 - 1; }
    if (c0 < 49 || c0 > 57) { return 0 - 1; }
    var n = c0 - 48;
    var i = 1;
    while (i < len) {
        var c = load8(buf + i);
        if (c < 48 || c > 57) { return 0 - 1; }
        n = n * 10 + (c - 48);
        i = i + 1;
    }
    return n;
}

# Unescape one reference token from (src, src_len) into a freshly
# allocated buffer. Layout: u64 length prefix at offset 0, decoded
# bytes from offset 8, NUL byte at offset 8+len. Returns the alloc
# pointer, or 0 on bad escape (lone "~" or "~X" where X != 0/1).
fn _jp_token_unescape(src, src_len): i64 {
    var out = alloc(src_len + 8 + 1);
    var oi = 0;
    var i = 0;
    while (i < src_len) {
        var c = load8(src + i);
        if (c == 126) {
            i = i + 1;
            if (i >= src_len) { return 0; }
            var e = load8(src + i);
            if      (e == 48) { store8(out + 8 + oi, 126); oi = oi + 1; }
            elif    (e == 49) { store8(out + 8 + oi,  47); oi = oi + 1; }
            else { return 0; }
            i = i + 1;
        } else {
            store8(out + 8 + oi, c);
            oi = oi + 1;
            i = i + 1;
        }
    }
    store8(out + 8 + oi, 0);
    store64(out, oi);
    return out;
}

# Public entry — explicit buf+len pointer string.
fn bayan_json_v_pointer_cstr(v, ptr, plen): i64 {
    if (v == 0) { return 0; }
    if (plen == 0) { return v; }
    if (load8(ptr) != 47) { return 0; }   # must start with '/'
    var pos = 1;
    var cur = v;
    while (pos <= plen) {
        var start = pos;
        while (pos < plen) {
            if (load8(ptr + pos) == 47) { break; }
            pos = pos + 1;
        }
        var tok_len = pos - start;
        var ub = _jp_token_unescape(ptr + start, tok_len);
        if (ub == 0) { return 0; }
        var ulen = load64(ub);
        var ubuf = ub + 8;
        if (cur == 0) { return 0; }
        var t = load64(cur);
        if (t == JTAG_OBJ) {
            cur = _jp_obj_lookup(cur, ubuf, ulen);
        } elif (t == JTAG_ARR) {
            var idx = _jp_parse_idx(ubuf, ulen);
            if (idx < 0) { return 0; }
            cur = bayan_json_v_arr_get(cur, idx);
        } else {
            return 0;
        }
        if (cur == 0) { return 0; }
        if (pos == plen) { return cur; }
        pos = pos + 1;
    }
    return cur;
}

# Convenience: pointer as a Str.
fn bayan_json_v_pointer(v, ptr): i64 {
    if (ptr == 0) { return v; }
    return bayan_json_v_pointer_cstr(v, str_data(ptr), str_len(ptr));
}

# --- yaml.cyr ---

# bayan — YAML subset parser -> the shared tagged value tree.
#
# Parses a pragmatic YAML subset into the SAME `JTAG_*`-tagged 24-byte
# `bayan_json_v_*` value cells the JSON value parser produces, so one
# consumer traverses one node shape regardless of input format (the
# serde-data-model property the Rust originals have). Filed by agnosai
# (definition files) and driven equally by mneme (Markdown frontmatter):
# docs/development/issues/2026-07-16-agnosai-yaml-parse-into-tagged-value-tree.md
#
# In the subset:
#   - block mappings (`key: value`), nested by indentation (spaces only);
#     plain or quoted keys
#   - block sequences (`- item`), incl. compact `- key: value` items and
#     sequences at the same indent as their parent mapping key
#   - flow sequences `[a, b, c]` (single-line, on the key line, nestable,
#     trailing comma ok)
#   - scalars: null / ~ / true / false, STRICT-JSON-grammar numbers
#     (INT/FLOAT; leading-zero `01` or digitless-exponent `1e` tokens fall
#     back to plain strings), single- or double-quoted strings (one quote
#     layer stripped, body VERBATIM — no \-escape decoding, matching the
#     toml module's convention), plain strings
#   - `#` comments (full-line or trailing, quote-aware) and blank lines.
#     A quote char opens a quoted region only at a token boundary (content
#     start, or after space / tab / `[` / `,`) — mid-word quotes (O'Brien,
#     5" nail) are literal text, in comment stripping and key splitting both
#   - one leading `---` document-start and one `...` document-end marker
#     (each on its own line)
#   - a single-line top-level scalar or flow-sequence document; an empty
#     document is JTAG_NULL; a leading UTF-8 BOM is skipped
#
# REJECTED LOUDLY (parse error, never a silent mis-parse):
#   - anchors/aliases (`&a` / `*a`), tags (`!` / `!!type`) — in value AND
#     key position
#   - block scalars (`|` / `>`); plain values led by `- ` or `? ` indicators
#   - flow mappings (`{k: v}`) and implicit flow-mapping entries (`[a: b]`)
#   - a second `---` (multi-document streams), content ON a `---`/`...`
#     marker line, content (or a second `...`) after `...`
#   - a flow sequence on its own line below the key (must follow the key)
#   - empty flow-sequence elements (`[,]` / `[a,,b]`; trailing comma is ok)
#   - tabs in indentation; unterminated flow sequences; unterminated or
#     malformed quoted scalars (content past the close quote)
#
# Out of subset entirely (not detected): lone-CR (classic Mac) line endings.
#
# Reentrancy + bounds: keys off the json module's per-call parser state
# (`_JP_STATE_SIZE` = 48 bytes — the same struct, so a caller reserves via
# bayan_json_parse_state_size()) and shares its recursion cap
# (`_JP_MAX_DEPTH` = 128, "nesting too deep") — both lessons applied from
# day one (thoth cursor issue 2026-06-23, agnosai depth-cap issue
# 2026-07-16). err_pos is a byte offset into the source buffer.
#
# Strings share the source buffer (no copy) like the toml parser — the
# source must outlive the returned tree. Node allocation flows through
# default_alloc(), matching the JSON value parser.
#
# NOTE (single-pass bundle order): this module references json.cyr internals
# (_jp_state_init / _jp_set_err / _jp_parse_number / constructors), so it
# must appear AFTER src/json.cyr in `[lib].modules` and in include lists.

# === Legacy last-error slots (mirror of the json module's convention) ===

var _yaml_err_msg = 0;
var _yaml_err_pos = 0;

# Return the last yaml parse error message (cstr) — set on bayan_yaml_parse*
# failure via the globals-compat entries. Concurrent callers use the ctx path
# and bayan_yaml_state_error() instead.
fn bayan_yaml_last_error(): i64 {
    if (_yaml_err_msg == 0) { return ""; }
    return _yaml_err_msg;
}

# Return the last yaml parse error byte offset.
fn bayan_yaml_last_error_pos(): i64 { return _yaml_err_pos; }

# Read the parse error from a caller-owned parser state (race-free). Thin
# forwarders over the shared state accessors.
fn bayan_yaml_state_error(ps): i64 { return bayan_json_state_error(ps); }

# Byte offset companion of bayan_yaml_state_error.
fn bayan_yaml_state_error_pos(ps): i64 { return bayan_json_state_error_pos(ps); }

# === Small helpers ===

# True if the token (ptr,len) equals the C string `s`.
fn _yp_tok_is(ptr, len, s): i64 {
    if (strlen(s) != len) { return 0; }
    return memeq(ptr, s, len);
}

# Trim ASCII space/tab from both ends of (ptr,len); returns new ptr via
# out-of-band: packs nothing — instead callers use _yp_trim_start/_yp_trim_len
# on their own. Kept as two passes to stay expression-free.
fn _yp_trim_start(ptr, len): i64 {
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (c == 32 || c == 9) { i = i + 1; }
        else { return i; }
    }
    return i;
}

# Length of (ptr,len) after trimming trailing space/tab.
fn _yp_trim_end(ptr, len): i64 {
    var n = len;
    while (n > 0) {
        var c = load8(ptr + n - 1);
        if (c == 32 || c == 9) { n = n - 1; }
        else { return n; }
    }
    return n;
}

# True if a quote char at index j of the content starting at `start` sits at
# a token boundary — content start, or after space / tab / `[` / `,`. Only
# there does it OPEN a quoted region; mid-word quotes (O'Brien, 5" nail) are
# literal text. Shared by the comment stripper and the key splitter so both
# agree on what is quoted.
fn _yp_quote_opens_at(ptr, start, j): i64 {
    if (j == start) { return 1; }
    var pc = load8(ptr + j - 1);
    if (pc == 32 || pc == 9 || pc == 91 || pc == 44) { return 1; }
    return 0;
}

# === Line records ===
#
# The scanner turns the input into a vec of 32-byte line records:
#   +0   off     i64   byte offset of the line's content start (for err_pos)
#   +8   ptr     cstr  first content byte (past indentation)
#   +16  len     i64   content length (comment-stripped, end-trimmed)
#   +24  indent  i64   leading-space count (the line's column)
# Blank lines, comment-only lines, and document markers never produce records.

# Scan (buf,len) into line records. Returns the vec, or 0 with the error set
# in ps (tab indentation, multi-document, content after `...`).
fn _yp_scan_lines(ps, buf, len): i64 {
    var lines = vec_new();
    var pos = 0;
    # skip a leading UTF-8 BOM so it can't be absorbed into the first key
    if (len >= 3 && load8(buf) == 239 && load8(buf + 1) == 187 && load8(buf + 2) == 191) {
        pos = 3;
    }
    var saw_doc_start = 0;
    var saw_content = 0;
    var ended = 0;
    while (pos < len) {
        # -- line extent [pos, eol), next line at nxt --
        var eol = pos;
        while (eol < len && load8(buf + eol) != 10) { eol = eol + 1; }
        var nxt = eol + 1;
        if (eol > pos && load8(buf + eol - 1) == 13) { eol = eol - 1; }   # strip \r
        # -- indentation: spaces only --
        var i = pos;
        while (i < eol && load8(buf + i) == 32) { i = i + 1; }
        if (i < eol && load8(buf + i) == 9) {
            _jp_set_err(ps, "tab in yaml indentation", i);
            return 0;
        }
        var indent = i - pos;
        # -- quote-aware comment strip: a `#` at content start, or preceded
        #    by space/tab, outside quotes, cuts the line --
        var q = 0;
        var cend = eol;
        var j = i;
        while (j < eol) {
            var c = load8(buf + j);
            if (q == 0) {
                if (c == 35) {
                    var at_start = 0;
                    if (j == i) { at_start = 1; }
                    else {
                        var pc = load8(buf + j - 1);
                        if (pc == 32 || pc == 9) { at_start = 1; }
                    }
                    if (at_start == 1) { cend = j; j = eol; }
                }
                if (j < eol) {
                    var c1 = load8(buf + j);
                    if (c1 == 34 || c1 == 39) {
                        if (_yp_quote_opens_at(buf, i, j) == 1) { q = c1; }
                    }
                }
            }
            else {
                if (c == q) { q = 0; }
            }
            j = j + 1;
        }
        var clen = _yp_trim_end(buf + i, cend - i);
        if (clen > 0) {
            # -- document markers (a marker line must carry NOTHING else:
            #    "--- foo" would otherwise be silently folded into the tree) --
            var handled = 0;
            if (clen >= 4) {
                var m3 = load8(buf + i + 3);
                if (m3 == 32 || m3 == 9) {
                    if (_yp_tok_is(buf + i, 3, "---") == 1) {
                        _jp_set_err(ps, "content on '---' marker line not supported", i);
                        return 0;
                    }
                    if (_yp_tok_is(buf + i, 3, "...") == 1) {
                        _jp_set_err(ps, "content on '...' marker line not supported", i);
                        return 0;
                    }
                }
            }
            if (_yp_tok_is(buf + i, clen, "---") == 1) {
                if (saw_content == 0 && saw_doc_start == 0) { saw_doc_start = 1; handled = 1; }
                else {
                    _jp_set_err(ps, "multi-document yaml not supported", i);
                    return 0;
                }
            }
            if (handled == 0) {
                if (_yp_tok_is(buf + i, clen, "...") == 1) {
                    if (ended == 1) {
                        _jp_set_err(ps, "content after '...' document end", i);
                        return 0;
                    }
                    ended = 1;
                    handled = 1;
                }
            }
            if (handled == 0) {
                if (ended == 1) {
                    _jp_set_err(ps, "content after '...' document end", i);
                    return 0;
                }
                saw_content = 1;
                var rec = alloc(32);
                store64(rec,      i);
                store64(rec + 8,  buf + i);
                store64(rec + 16, clen);
                store64(rec + 24, indent);
                vec_push(lines, rec);
            }
        }
        pos = nxt;
    }
    return lines;
}

# === Scalar typing ===

# True if (ptr,len) is EXACTLY a strict-JSON-grammar number:
#   -?(0|[1-9][0-9]*)(\.[0-9]+)?([eE][+-]?[0-9]+)?
# The shared _jp_parse_number scanner is laxer (digitless exponents, leading
# zeros), so this gate keeps the module's "JSON-syntax numbers" contract:
# "01", "1.", "1e", "1e+" all fall back to plain strings.
fn _yp_is_json_number(ptr, len): i64 {
    var i = 0;
    if (i < len && load8(ptr + i) == 45) { i = i + 1; }        # -
    if (i >= len) { return 0; }
    var c = load8(ptr + i);
    if (c == 48) { i = i + 1; }                                # 0
    else {
        if (c < 49 || c > 57) { return 0; }                    # [1-9]
        while (i < len) {
            var d = load8(ptr + i);
            if (d >= 48 && d <= 57) { i = i + 1; }
            else { break; }
        }
    }
    if (i < len && load8(ptr + i) == 46) {                     # .[0-9]+
        i = i + 1;
        if (i >= len) { return 0; }
        var f = load8(ptr + i);
        if (f < 48 || f > 57) { return 0; }
        while (i < len) {
            var d2 = load8(ptr + i);
            if (d2 >= 48 && d2 <= 57) { i = i + 1; }
            else { break; }
        }
    }
    if (i < len) {                                             # [eE][+-]?[0-9]+
        var e = load8(ptr + i);
        if (e == 101 || e == 69) {
            i = i + 1;
            if (i < len) {
                var sg = load8(ptr + i);
                if (sg == 43 || sg == 45) { i = i + 1; }
            }
            if (i >= len) { return 0; }
            var x = load8(ptr + i);
            if (x < 48 || x > 57) { return 0; }
            while (i < len) {
                var d3 = load8(ptr + i);
                if (d3 >= 48 && d3 <= 57) { i = i + 1; }
                else { break; }
            }
        }
    }
    if (i == len) { return 1; }
    return 0;
}

# Try (ptr,len) as a number. Returns an INT/FLOAT node, or 0 if the token is
# not entirely a strict-JSON number (caller falls through to string). The
# actual conversion reuses the json module's scanner so YAML and JSON type
# accepted numbers identically.
fn _yp_try_number(ptr, len): i64 {
    if (_yp_is_json_number(ptr, len) == 0) { return 0; }
    var nps[48];
    _jp_state_init(&nps, ptr, len);
    var v = _jp_parse_number(&nps);
    if (v == 0) { return 0; }
    if (load64(&nps + 16) != len) { return 0; }   # cannot happen post-gate; belt+braces
    return v;
}

# Reject out-of-subset value forms by leading byte: anchors/aliases, tags,
# block scalars, flow mappings. Returns -1 with the error set, else 0.
fn _yp_reject_check(ps, ptr, len, off): i64 {
    if (len == 0) { return 0; }
    var c = load8(ptr);
    if (c == 38 || c == 42) {   # & *
        _jp_set_err(ps, "yaml anchors/aliases not supported", off);
        return 0 - 1;
    }
    if (c == 33) {              # !
        _jp_set_err(ps, "yaml tags not supported", off);
        return 0 - 1;
    }
    if (c == 124 || c == 62) {  # | >
        _jp_set_err(ps, "yaml block scalars not supported", off);
        return 0 - 1;
    }
    if (c == 123) {             # {
        _jp_set_err(ps, "yaml flow mappings not supported", off);
        return 0 - 1;
    }
    if (c == 45 && len >= 2) {  # `- ` — a sequence indicator is not a scalar
        var n1 = load8(ptr + 1);
        if (n1 == 32 || n1 == 9) {
            _jp_set_err(ps, "unexpected '-' sequence indicator in scalar", off);
            return 0 - 1;
        }
    }
    if (c == 63) {              # `?` / `? ` — complex mapping keys
        var is_ck = 0;
        if (len == 1) { is_ck = 1; }
        else {
            var n2 = load8(ptr + 1);
            if (n2 == 32 || n2 == 9) { is_ck = 1; }
        }
        if (is_ck == 1) {
            _jp_set_err(ps, "yaml complex keys ('?') not supported", off);
            return 0 - 1;
        }
    }
    return 0;
}

# Type a PLAIN (unquoted, non-flow) scalar token: null/~/true/false, number,
# else a string sharing the source buffer. (ptr,len) is already trimmed.
fn _yp_plain_scalar(ptr, len): i64 {
    if (len == 0)                          { return bayan_json_v_null(); }
    if (_yp_tok_is(ptr, len, "null") == 1) { return bayan_json_v_null(); }
    if (_yp_tok_is(ptr, len, "~") == 1)    { return bayan_json_v_null(); }
    if (_yp_tok_is(ptr, len, "true") == 1) { return bayan_json_v_bool_new(1); }
    if (_yp_tok_is(ptr, len, "false") == 1){ return bayan_json_v_bool_new(0); }
    var num = _yp_try_number(ptr, len);
    if (num != 0) { return num; }
    return bayan_json_v_str_new(str_new(ptr, len));
}

# Parse a quoted scalar: (ptr,len) starts with `"` or `'`. Single-line; the
# last byte must be the matching close quote. Body captured VERBATIM (one
# layer stripped, no escape decoding — the toml convention).
fn _yp_quoted(ps, ptr, len, off): i64 {
    var q = load8(ptr);
    if (len < 2) {
        _jp_set_err(ps, "unterminated quoted scalar", off);
        return 0;
    }
    # the FIRST close quote must also be the last byte — `"a" "b"` and
    # `"a"b"` are malformed, not silently glued strings
    var k = 1;
    while (k < len && load8(ptr + k) != q) { k = k + 1; }
    if (k >= len) {
        _jp_set_err(ps, "unterminated quoted scalar", off);
        return 0;
    }
    if (k != len - 1) {
        _jp_set_err(ps, "malformed quoted scalar", off);
        return 0;
    }
    return bayan_json_v_str_new(str_new(ptr + 1, len - 2));
}

# === Flow sequences ===

# Parse a flow sequence from (ptr,len) starting at *cur (which must index a
# `[`). Advances *cur past the closing `]`. Depth-capped via ps. Elements:
# nested flow sequences, quoted scalars, plain scalars (up to `,` / `]`).
fn _yp_parse_flow_seq(ps, ptr, len, cur, off): i64 {
    var depth = load64(ps + 40);
    if (depth >= _JP_MAX_DEPTH) {
        _jp_set_err(ps, "nesting too deep", off + load64(cur));
        return 0;
    }
    store64(ps + 40, depth + 1);
    var arr = bayan_json_v_arr_new();
    var ix = load64(cur) + 1;   # past '['
    while (1 == 1) {
        while (ix < len) {      # skip inter-element whitespace
            var c = load8(ptr + ix);
            if (c == 32 || c == 9) { ix = ix + 1; }
            else { break; }
        }
        if (ix >= len) {
            _jp_set_err(ps, "unterminated flow sequence", off + ix);
            return 0;
        }
        var c = load8(ptr + ix);
        if (c == 93) {          # ]
            store64(cur, ix + 1);
            store64(ps + 40, load64(ps + 40) - 1);
            return arr;
        }
        # -- element --
        var item = 0;
        if (c == 91) {          # [ nested
            store64(cur, ix);
            item = _yp_parse_flow_seq(ps, ptr, len, cur, off);
            if (item == 0) { return 0; }
            ix = load64(cur);
        }
        else {
            if (c == 34 || c == 39) {   # quoted element
                var close = ix + 1;
                while (close < len && load8(ptr + close) != c) { close = close + 1; }
                if (close >= len) {
                    _jp_set_err(ps, "unterminated quoted scalar", off + ix);
                    return 0;
                }
                item = bayan_json_v_str_new(str_new(ptr + ix + 1, close - ix - 1));
                ix = close + 1;
            }
            else {
                if (_yp_reject_check(ps, ptr + ix, len - ix, off + ix) != 0) { return 0; }
                var e = ix;     # plain element: up to , or ]
                while (e < len) {
                    var ec = load8(ptr + e);
                    if (ec == 44 || ec == 93) { break; }
                    e = e + 1;
                }
                var tlen = _yp_trim_end(ptr + ix, e - ix);
                if (tlen == 0) {    # `[,]` / `[a,,b]` — no phantom nulls
                    _jp_set_err(ps, "empty flow-sequence element", off + ix);
                    return 0;
                }
                # `[a: b]` is an implicit flow-mapping entry, not a string
                if (_yp_find_colon(ptr + ix, tlen) >= 0) {
                    _jp_set_err(ps, "yaml flow mappings not supported", off + ix);
                    return 0;
                }
                item = _yp_plain_scalar(ptr + ix, tlen);
                ix = e;
            }
        }
        bayan_json_v_arr_push(arr, item);
        while (ix < len) {      # skip ws to separator/close
            var sc = load8(ptr + ix);
            if (sc == 32 || sc == 9) { ix = ix + 1; }
            else { break; }
        }
        if (ix >= len) {
            _jp_set_err(ps, "unterminated flow sequence", off + ix);
            return 0;
        }
        var sep = load8(ptr + ix);
        if (sep == 44) { ix = ix + 1; }     # , (trailing comma ok — loop re-checks ])
        else {
            if (sep != 93) {
                _jp_set_err(ps, "expected ',' or ']' in flow sequence", off + ix);
                return 0;
            }
        }
    }
    return 0;
}

# === Line-value dispatch ===

# Parse a whole-line value token (ptr,len) at source offset `off`: flow
# sequence, quoted scalar, or (reject-checked) plain scalar.
fn _yp_line_value(ps, ptr, len, off): i64 {
    if (len == 0) { return bayan_json_v_null(); }
    var c = load8(ptr);
    if (c == 91) {              # [ flow sequence — must consume the token
        var cx[8];
        store64(&cx, 0);
        var v = _yp_parse_flow_seq(ps, ptr, len, &cx, off);
        if (v == 0) { return 0; }
        var ix = load64(&cx);
        while (ix < len) {
            var tc = load8(ptr + ix);
            if (tc == 32 || tc == 9) { ix = ix + 1; }
            else { break; }
        }
        if (ix != len) {
            _jp_set_err(ps, "content after flow sequence", off + ix);
            return 0;
        }
        return v;
    }
    if (c == 34 || c == 39) { return _yp_quoted(ps, ptr, len, off); }
    if (_yp_reject_check(ps, ptr, len, off) != 0) { return 0; }
    return _yp_plain_scalar(ptr, len);
}

# === Block structure ===

# Find the mapping colon in (ptr,len): a `:` outside quotes whose successor
# is space/tab or end-of-line. Returns its index or -1. (A plain `url:
# http://x` value is safe — the FIRST qualifying colon ends the key.)
fn _yp_find_colon(ptr, len): i64 {
    var q = 0;
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (q == 0) {
            var opens = 0;
            if (c == 34 || c == 39) { opens = _yp_quote_opens_at(ptr, 0, i); }
            if (opens == 1) { q = c; }
            else {
                if (c == 58) {
                    if (i + 1 >= len) { return i; }
                    var nc = load8(ptr + i + 1);
                    if (nc == 32 || nc == 9) { return i; }
                }
            }
        }
        else {
            if (c == q) { q = 0; }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# True if line content (ptr,len) is a block-sequence entry: `-` alone or `- x`.
fn _yp_is_seq_line(ptr, len): i64 {
    if (len == 0) { return 0; }
    if (load8(ptr) != 45) { return 0; }
    if (len == 1) { return 1; }
    var c = load8(ptr + 1);
    if (c == 32 || c == 9) { return 1; }
    return 0;
}

# yc — parse context over the scanned lines (stack struct, 24 bytes):
#   +0 lines vec   +8 idx   +16 nlines
fn _yc_cur(yc): i64 {
    var idx = load64(yc + 8);
    if (idx >= load64(yc + 16)) { return 0; }
    return vec_get(load64(yc), idx);
}

# Advance the line cursor.
fn _yc_advance(yc): i64 {
    store64(yc + 8, load64(yc + 8) + 1);
    return 0;
}

# Parse the block starting at the current line, which must sit at exactly
# `indent`. Dispatches sequence vs mapping; depth-capped via ps (+40).
fn _yp_parse_block(ps, yc, indent): i64 {
    var depth = load64(ps + 40);
    var rec = _yc_cur(yc);
    if (rec == 0) { return bayan_json_v_null(); }
    if (depth >= _JP_MAX_DEPTH) {
        _jp_set_err(ps, "nesting too deep", load64(rec));
        return 0;
    }
    store64(ps + 40, depth + 1);
    var v = 0;
    if (_yp_is_seq_line(load64(rec + 8), load64(rec + 16)) == 1) {
        v = _yp_parse_sequence(ps, yc, indent);
    }
    else {
        v = _yp_parse_mapping(ps, yc, indent);
    }
    store64(ps + 40, load64(ps + 40) - 1);
    return v;
}

# Parse consecutive mapping entries at exactly `indent` into a JTAG_OBJ.
# A dedented line ends the mapping (parent's problem); a deeper line is an
# error; a `- ` entry at this indent inside a mapping is an error.
fn _yp_parse_mapping(ps, yc, indent): i64 {
    var obj = bayan_json_v_obj_new();
    while (1 == 1) {
        var rec = _yc_cur(yc);
        if (rec == 0) { return obj; }
        var ri = load64(rec + 24);
        if (ri < indent) { return obj; }
        var roff = load64(rec);
        var rptr = load64(rec + 8);
        var rlen = load64(rec + 16);
        if (ri > indent) {
            _jp_set_err(ps, "unexpected indentation", roff);
            return 0;
        }
        if (_yp_is_seq_line(rptr, rlen) == 1) {
            _jp_set_err(ps, "unexpected sequence entry in mapping", roff);
            return 0;
        }
        if (load8(rptr) == 91) {    # a bare `[...]` line can't open a mapping
            _jp_set_err(ps, "flow sequence must follow its key on the same line", roff);
            return 0;
        }
        var ci = _yp_find_colon(rptr, rlen);
        if (ci < 0) {
            _jp_set_err(ps, "expected ':' in mapping entry", roff);
            return 0;
        }
        # -- key: trimmed; one quote layer stripped if fully quoted --
        var klen = _yp_trim_end(rptr, ci);
        var kptr = rptr;
        if (klen == 0) {
            _jp_set_err(ps, "empty mapping key", roff);
            return 0;
        }
        var kq = load8(kptr);
        if (kq == 34 || kq == 39) {
            if (klen >= 2 && load8(kptr + klen - 1) == kq) {
                kptr = kptr + 1;
                klen = klen - 2;
            }
        }
        else {
            # anchors/tags/indicators are as out-of-subset in KEY position
            # as in value position — reject, don't stringify
            if (_yp_reject_check(ps, kptr, klen, roff) != 0) { return 0; }
        }
        # -- rest of line after the colon --
        var vstart = ci + 1;
        var voff = _yp_trim_start(rptr + vstart, rlen - vstart);
        var vptr = rptr + vstart + voff;
        var vlen = _yp_trim_end(vptr, rlen - vstart - voff);
        _yc_advance(yc);
        var val = 0;
        if (vlen > 0) {
            val = _yp_line_value(ps, vptr, vlen, roff + (vptr - rptr));
        }
        else {
            # `key:` with nothing after — nested block (deeper, or a sequence
            # at the same indent), else null
            var nrec = _yc_cur(yc);
            if (nrec == 0) { val = bayan_json_v_null(); }
            else {
                var nin = load64(nrec + 24);
                if (nin > indent) { val = _yp_parse_block(ps, yc, nin); }
                else {
                    if (nin == indent && _yp_is_seq_line(load64(nrec + 8), load64(nrec + 16)) == 1) {
                        val = _yp_parse_block(ps, yc, indent);
                    }
                    else { val = bayan_json_v_null(); }
                }
            }
        }
        if (val == 0) { return 0; }
        bayan_json_v_obj_set(obj, str_new(kptr, klen), val);
    }
    return 0;
}

# Parse consecutive `- ` entries at exactly `indent` into a JTAG_ARR.
# Supports scalar/flow items, `-` alone + deeper block, and compact
# `- key: value` / `- - x` items (the item re-anchors at the rest column).
fn _yp_parse_sequence(ps, yc, indent): i64 {
    var arr = bayan_json_v_arr_new();
    while (1 == 1) {
        var rec = _yc_cur(yc);
        if (rec == 0) { return arr; }
        var ri = load64(rec + 24);
        if (ri < indent) { return arr; }
        var roff = load64(rec);
        var rptr = load64(rec + 8);
        var rlen = load64(rec + 16);
        if (ri > indent) {
            _jp_set_err(ps, "unexpected indentation", roff);
            return 0;
        }
        if (_yp_is_seq_line(rptr, rlen) == 0) { return arr; }   # back to parent mapping
        var item = 0;
        if (rlen == 1) {
            # bare `-` — item is a deeper block, else null
            _yc_advance(yc);
            var nrec = _yc_cur(yc);
            item = bayan_json_v_null();
            if (nrec != 0) {
                if (load64(nrec + 24) > indent) {
                    item = _yp_parse_block(ps, yc, load64(nrec + 24));
                }
            }
        }
        else {
            # `- rest` — rest starts past the dash + spaces
            var j = 1 + _yp_trim_start(rptr + 1, rlen - 1);
            var restp = rptr + j;
            var restl = rlen - j;
            var restcol = ri + j;
            var restoff = roff + j;
            var compact = 0;
            if (load8(restp) != 91) {                       # flow item is never compact
                if (_yp_is_seq_line(restp, restl) == 1) { compact = 1; }
                else {
                    if (_yp_find_colon(restp, restl) >= 0) { compact = 1; }
                }
            }
            if (compact == 1) {
                # re-anchor the record at the rest column and parse the whole
                # nested block (its continuation lines sit at restcol)
                store64(rec,      restoff);
                store64(rec + 8,  restp);
                store64(rec + 16, restl);
                store64(rec + 24, restcol);
                item = _yp_parse_block(ps, yc, restcol);
            }
            else {
                _yc_advance(yc);
                item = _yp_line_value(ps, restp, restl, restoff);
            }
        }
        if (item == 0) { return 0; }
        bayan_json_v_arr_push(arr, item);
    }
    return 0;
}

# === Public parse entries ===

# Reentrant parse — caller owns ps (bayan_json_parse_state_size() bytes; the
# yaml parser shares the json parser-state struct). Returns json_v* or 0 with
# the error in bayan_yaml_state_error(ps)/_pos(ps). Touches no globals.
fn bayan_yaml_parse_ctx(ps, buf, len): i64 {
    _jp_state_init(ps, buf, len);
    var lines = _yp_scan_lines(ps, buf, len);
    if (lines == 0) { return 0; }
    var n = vec_len(lines);
    if (n == 0) { return bayan_json_v_null(); }   # empty document
    var yc[24];
    store64(&yc,      lines);
    store64(&yc + 8,  0);
    store64(&yc + 16, n);
    var first = vec_get(lines, 0);
    var base = load64(first + 24);
    var fptr = load64(first + 8);
    var flen = load64(first + 16);
    # top-level flow-sequence document: `[...]` on the first line is a value
    # line, never a mapping (a ': ' inside the brackets must not key-split it)
    if (load8(fptr) == 91) {
        if (n == 1) { return _yp_line_value(ps, fptr, flen, load64(first)); }
        _jp_set_err(ps, "unexpected line", load64(vec_get(lines, 1)));
        return 0;
    }
    # top-level scalar document: a single line that is neither a mapping
    # entry nor a sequence entry
    if (_yp_is_seq_line(fptr, flen) == 0) {
        if (_yp_find_colon(fptr, flen) < 0) {
            if (n == 1) { return _yp_line_value(ps, fptr, flen, load64(first)); }
            _jp_set_err(ps, "expected mapping or sequence entry", load64(first));
            return 0;
        }
    }
    var v = _yp_parse_block(ps, &yc, base);
    if (v == 0) { return 0; }
    if (load64(&yc + 8) < n) {
        var left = _yc_cur(&yc);
        _jp_set_err(ps, "unexpected line", load64(left));
        return 0;
    }
    return v;
}

# Reentrant parse — Str convenience over bayan_yaml_parse_ctx.
fn bayan_yaml_parse_ctx_str(ps, src): i64 {
    if (src == 0) {
        _jp_state_init(ps, 0, 0);
        _jp_set_err(ps, "null source", 0);
        return 0;
    }
    return bayan_yaml_parse_ctx(ps, str_data(src), str_len(src));
}

# Public parse entry — explicit cstr+len. Globals-compat wrapper over the
# reentrant path (stack-local state per call, so the parse itself is
# thread-safe); mirrors the per-call error into bayan_yaml_last_error()/_pos().
fn bayan_yaml_parse_str(buf, len): i64 {
    var ps[48];
    var v = bayan_yaml_parse_ctx(&ps, buf, len);
    _yaml_err_msg = load64(&ps + 24);
    _yaml_err_pos = load64(&ps + 32);
    return v;
}

# Public parse entry — Str. Returns json_v* or 0.
fn bayan_yaml_parse(src): i64 {
    if (src == 0) { _yaml_err_msg = "null source"; _yaml_err_pos = 0; return 0; }
    return bayan_yaml_parse_str(str_data(src), str_len(src));
}

# === Frontmatter split ===
#
# Split a Markdown document with optional YAML frontmatter:
#   ---            <- first line, exactly
#   <yaml...>
#   ---  (or ...)  <- closing fence line, exactly
#   <body...>
# Returns a 16-byte pair { yaml: Str|0 @ +0, body: Str @ +8 }. Without a
# well-formed frontmatter block (no leading `---`, or no closing fence),
# yaml is 0 and body is the whole input — mirroring the mneme interim
# parser's behavior. Both Strs share the source buffer (no copy).

# True if line [ls, le) (exclusive, \r already excluded) is exactly `---`
# or `...`.
fn _yfm_is_fence(buf, ls, le): i64 {
    if (le - ls != 3) { return 0; }
    var c = load8(buf + ls);
    if (c != 45 && c != 46) { return 0; }
    if (load8(buf + ls + 1) != c) { return 0; }
    if (load8(buf + ls + 2) != c) { return 0; }
    return 1;
}

# Allocator-threading variant of bayan_yaml_frontmatter_split.
fn bayan_yaml_frontmatter_split_a(a, src): i64 {
    var p = alloc_via(a, 16);
    var buf = str_data(src);
    var len = str_len(src);
    store64(p, 0);
    store64(p + 8, src);
    # -- first line must be exactly --- --
    var e0 = 0;
    while (e0 < len && load8(buf + e0) != 10) { e0 = e0 + 1; }
    var t0 = e0;
    if (t0 > 0 && load8(buf + t0 - 1) == 13) { t0 = t0 - 1; }
    if (_yfm_is_fence(buf, 0, t0) == 0) { return p; }
    if (load8(buf) != 45) { return p; }            # `...` can't OPEN a block
    if (e0 >= len) { return p; }                   # `---` with no newline: no block
    # -- find the closing fence line --
    var ls = e0 + 1;
    while (ls <= len) {
        var le = ls;
        while (le < len && load8(buf + le) != 10) { le = le + 1; }
        var te = le;
        if (te > ls && load8(buf + te - 1) == 13) { te = te - 1; }
        if (_yfm_is_fence(buf, ls, te) == 1) {
            var bstart = le + 1;
            if (bstart > len) { bstart = len; }
            store64(p, str_new_a(a, buf + e0 + 1, ls - e0 - 1));
            store64(p + 8, str_new_a(a, buf + bstart, len - bstart));
            return p;
        }
        ls = le + 1;
    }
    return p;                                      # no closing fence
}

# Split Markdown into { yaml frontmatter | 0, body }. See above.
fn bayan_yaml_frontmatter_split(src): i64 {
    return bayan_yaml_frontmatter_split_a(default_alloc(), src);
}

# Frontmatter-pair accessor: the yaml Str (0 when no frontmatter was found).
fn bayan_yaml_fm_yaml(p): i64 { return load64(p); }

# Frontmatter-pair accessor: the body Str (whole input when no frontmatter).
fn bayan_yaml_fm_body(p): i64 { return load64(p + 8); }
